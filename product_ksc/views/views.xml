<odoo>

    <!-- Tree View -->
    <record id="view_product_list" model="ir.ui.view">
        <field name="name">product.list</field>
        <field name="model">product</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="sku"/>
                <field name="barcode"/>
                <field name="product_type"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_product_form" model="ir.ui.view">
        <field name="name">product.form</field>
        <field name="model">product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="sku"/>
                        <field name="barcode"/>
                        <field name="can_be_sold"/>
                        <field name="product_type"/>
                    </group>

                    <group>
                        <field name="sale_price"/>
                        <field name="cost_price"/>
                        <field name="warehouse"/>
                        <field name="active"/>
                    </group>

                    <group>
                        <field name="product_image"/>
                    </group>

                    <notebook>
                        <page string="Website Description">
                            <field name="website_description"/>
                        </page>
                        <page string="Internal Note">
                            <field name="internal_note"/>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_product_search" model="ir.ui.view">
        <field name="name">product.search</field>
        <field name="model">product</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="sku"/>
                <field name="barcode"/>
                <field name="can_be_sold"/>
                <field name="product_type"/>
            </search>
        </field>
    </record>

    <menuitem id="menu_my_sales" name="My Sales KSC"/>

    <menuitem id="menu_product_parent"
              name="Products"
              parent="menu_my_sales"
              sequence="10"/>

    <record id="action_product_ksc" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_product_ksc"
              name="Products"
              parent="menu_product_parent"
              action="action_product_ksc"
              sequence="10"/>



</odoo>
