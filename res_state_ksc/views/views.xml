<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="state_list_view" model="ir.ui.view">
        <field name="name">state.list.view</field>
        <field name="model">state</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="sh_name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="state_form_view" model="ir.ui.view">
        <field name="name">state.form.view</field>
        <field name="model">state</field>
        <field name="arch" type="xml">
            <form>
                <group>
                <field name="name"/>
                <field name="sh_name"/>
                <field name="active"/>
                </group>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="state_action" model="ir.actions.act_window">
        <field name="name">state</field>
        <field name="res_model">state</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENUS -->
    <menuitem id="Localization" name="States"/>
    <menuitem id="state_child" name="States" parent="Localization" action="state_action"/>



</odoo>
