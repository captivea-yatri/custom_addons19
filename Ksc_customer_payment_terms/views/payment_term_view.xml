<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.ui.view" id="inherited_account_view_payment_term_form">
        <field name="name">inherited_account_view_payment_term_form</field>
        <field name="model">account.payment.term</field>
        <field name="inherit_id" ref="account.view_payment_term_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='display_on_invoice']" position="after">
                <group>
                    <field name="is_default"/>
                    <field name="is_default_after_first_payment"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>