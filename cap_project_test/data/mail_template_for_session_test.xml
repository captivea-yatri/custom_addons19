<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="mail_template_for_session_test">
        <table border="0" cellpadding="0" cellspacing="0"
               style="padding-top: 10px; font-family:Verdana, Arial,sans-serif; background-color: white; color: #454748; width: 100%; border-collapse:separate;">
            <tbody>
                <!-- HEADER -->
                <tr>
                    <td style="min-width: 590px;">
                        <table border="0" cellpadding="0" cellspacing="0" width="100%"
                               style="background-color: white; padding: 0; border-collapse:separate;">
                            <tr>
                                <td valign="middle">
                                    <img t-attf-src="/logo.png?company={{ object.sudo().create_uid.sudo().company_id.id }}"
                                         style="padding: 0px; margin: 0px; height: 48px;"
                                         t-att-alt="object.sudo().create_uid.sudo().company_id.name"/>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" style="text-align:center;">
                                    <hr width="100%"
                                        style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin:4px 0px 32px 0px;"/>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
                <!-- CONTENT -->
                <tr>
                    <td style="min-width: 590px;">
                        <span>Dear
                            <b>
                                <t t-esc="assignee_name"/>
                            </b>
                            ,
                        </span>
                        <br/>
                        <br/>
                        <t t-if="object.message">
                            <b>Kindly see the details below for performing this session test:</b>
                            <span>
                                <t t-esc="object.message"/>
                            </span>
                            <br/>
                        </t>
                        <span style="margin-top: 8px;">New session test
                            <b>
                                <t t-esc="object.name"/>
                            </b>
                            is assigned to You.
                            <br/>
                            <br/>
                            <div>
                                <a t-att-href="'/my/test/%s' % object.id"
                                   class="btn btn-primary" style="width: 20%">
                                    View Session Test
                                </a>
                            </div>
                            <br/>
                        </span>
                    </td>
                </tr>
                <!-- FOOTER -->
                <tr>
                    <td style="min-width: 590px; padding: 0 8px 0 8px; font-size:11px;">
                        <hr width="100%"
                            style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 4px 0px;"/>
                        <b t-out="object.sudo().create_uid.sudo().company_id.name or ''">My Company (San Francisco)</b>
                        <br/>
                        <div style="color: #999999;">
                            <t t-out="object.sudo().create_uid.sudo().company_id.phone or ''">+1 650-123-4567</t>
                            <t t-if="object.sudo().create_uid.sudo().company_id.email">
                                |
                                <a t-attf-href="'mailto:%s' % {{ object.sudo().create_uid.sudo().company_id.email }}"
                                   style="text-decoration:none; color: #999999;"
                                   t-out="object.sudo().create_uid.sudo().company_id.email or ''">info@yourcompany.com
                                </a>
                            </t>
                            <t t-if="object.sudo().create_uid.sudo().company_id.website">
                                |
                                <a t-attf-href="'%s' % {{ object.sudo().create_uid.sudo().company_id.website }}"
                                   style="text-decoration:none; color: #999999;"
                                   t-out="object.sudo().create_uid.sudo().company_id.website or ''">
                                    http://www.example.com
                                </a>
                            </t>
                        </div>
                    </td>
                </tr>

                <tr>
                    <td style="min-width: 590px; padding: 0 8px 0 8px; font-size:11px;">
                        Powered by
                        <a target="_blank" href="https://www.odoo.com?utm_source=db&amp;utm_medium=email"
                           style="color: #875A7B;">Odoo
                        </a>
                    </td>
                </tr>
            </tbody>
            <!-- POWERED BY -->
        </table>
    </template>
</odoo>
