<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="project_requirement_inherit_view" model="ir.ui.view">
            <field name="name">project.requirement.inherit.view</field>
            <field name="model">project.requirement</field>
            <field name="inherit_id" ref="cap_requirements.project_requirement_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('oe_title')]" position="before">
                    <div class="oe_button_box" name="button_box">
                        <button name="action_project_object"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-flask icon"
                                context="{'search_default_groupby_date': 1}">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Task</span>
                                <span class="o_stat_text">Test</span>
                            </div>
                        </button>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
