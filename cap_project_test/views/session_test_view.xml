<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="session_test_tree_view" model="ir.ui.view">
            <field name="name">session.test.tree.view</field>
            <field name="model">session.test</field>
            <field name="arch" type="xml">
                <list default_order="date desc">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="branch"/>
                    <field name="phase_id"/>
                    <field name="domain_ids" widget="many2many_tags"/>
                    <field name="task_ids" widget="many2many_tags"/>
                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                    <field name="assigned_user_id"/>
                    <field name="pick_only" string="Pick only test that failed last time"/>
                    <field name="no_of_success_execution_test_object" string="Success"/>
                    <field name="no_of_failed_execution_test_object" string="Failed"/>
                    <field name="no_of_skipped_execution_test_object" string="Skipped"/>
                    <field name="no_of_todo_execution_test_object" string="To do"/>
                </list>
            </field>
        </record>

        <record id="session_test_form_view" model="ir.ui.view">
            <field name="name">session.test.form.view</field>
            <field name="model">session.test</field>
            <field name="arch" type="xml">
                <form duplicate="1">
                    <header>
                        <button name="action_create_execution_test"
                                string="Initialize Tests" type="object"
                                invisible="hide_the_initialize_button == True or status == 'cancel'" class="oe_highlight"/>
                        <button name="session_test_message_auto_subscribe_notify"
                                string="Send Invitation Email To Assigned User" type="object"
                                invisible="hide_the_initialize_button == False or status in ['closed', 'signed','cancel']"/>
                        <button name="cancel_execution_test"
                                    type="object"  string="Cancel"
                                    class="oe_stat_button"
                                invisible="status not in ['draft', 'sent', 'in progress']"/>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box" groups="base.group_user">
                            <button class="oe_stat_button" name="action_execution_test" type="object"
                                    icon="fa-check-square-o icon">
                                <div class="o_stat_info o_field_widget">
                                    <span class="o_stat_text">
                                        Execution
                                    </span>
                                    <span class="o_stat_text">
                                        Test
                                    </span>
                                </div>
                            </button>
                            <button class="oe_stat_button" name="action_task_validation_status" type="object"
                                    icon="fa-solid fa-check">
                                <div class="o_stat_info o_field_widget">
                                    <span class="o_stat_text">
                                        Task Validation
                                    </span>
                                    <span class="o_stat_text">
                                        Status
                                    </span>
                                </div>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name" readonly="hide_the_initialize_button == True" />
                                <field name="date" readonly="hide_the_initialize_button == True"/>
                                <field name="project_id" options="{'no_create': True, 'no_create_edit': True}"
                                       required="1" readonly="hide_the_initialize_button == True"/>
                                <field name="branch" readonly="hide_the_initialize_button == True"/>
                                <field name="assigned_user_id"
                                       readonly="hide_the_initialize_button == True"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="signer_id" required="1"
                                       readonly="hide_the_initialize_button == True"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="file_name" invisible="1"/>
                                <field name="file" filename="file_name"/>
                                <field name="attachment_id" invisible="1"/>
                                <field name="hide_the_initialize_button" invisible="1"/>
                                <field name="assigned_user_ids" invisible="1"/>
                            </group>
                            <group>
                                <field name="execution_test_ids" invisible="1"/>
                                <field name="pick_only"
                                       readonly="hide_the_initialize_button == True"/>
                                <field name="task_ids" widget="many2many_tags"
                                       domain="[('project_id', '=', project_id)]"
                                       readonly="hide_the_initialize_button == True"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="phase_id" context="{'project_id': project_id}"
                                       domain="[('project_id', '=', project_id)]"
                                       readonly="hide_the_initialize_button == True"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="domain_ids" widget="many2many_tags"
                                       readonly="hide_the_initialize_button == True"
                                       context="{'project_id': project_id}"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="tag_ids" widget="many2many_tags"
                                       readonly="hide_the_initialize_button == True"
                                       context="{'project_id': project_id}" options="{'color_field': 'color'}"/>
                                <field name="message"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Other Info">
                                <group>
                                    <group>
                                        <field name="total_no_of_execution"/>
                                        <field name="no_of_success_execution_test_object"/>
                                        <field name="no_of_todo_execution_test_object"/>
                                    </group>
                                    <group>
                                        <field name="no_of_failed_execution_test_object"/>
                                        <field name="no_of_skipped_execution_test_object"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="session_test_search_view" model="ir.ui.view">
            <field name="name">session.test.search.view</field>
            <field name="model">session.test</field>
            <field name="arch" type="xml">
                <search>
                    <field name="date"/>
                    <field name="assigned_user_id"/>
                    <field name="project_id"/>
                    <field name="phase_id"/>
                    <field name="domain_ids"/>
                    <field name="task_ids"/>
                    <field name="status"/>
                    <field name="tag_ids"/>
                    <separator/>
                    <filter name="status_draft" string="Draft" domain="[('status', '=', 'draft')]"/>
                    <filter name="status_sent" string="Sent" domain="[('status', '=', 'sent')]"/>
                    <filter name="status_in_progress" string="In Progress" domain="[('status', '=', 'in progress')]"/>
                    <filter name="status_closed" string="Closed" domain="[('status', '=', 'closed')]"/>
                    <filter name="status_signed" string="Signed" domain="[('status', '=', 'signed')]"/>

                        <filter string="Date" name="date" context="{'group_by':'date'}"/>
                        <filter string="Assigned User" name="assigned_user_id"
                                context="{'group_by':'assigned_user_id'}"/>
                        <filter string="Project" name="project_id"
                                context="{'group_by':'project_id'}"/>
                        <filter string="Phase" name="phase_id"
                                context="{'group_by':'phase_id'}"/>
                        <filter string="Domain" name="domain_ids"
                                context="{'group_by':'domain_ids'}"/>
                        <filter string="Tasks" name="task_ids"
                                context="{'group_by':'task_ids'}"/>
                        <filter string="Status" name="status"
                                context="{'group_by':'status'}"/>
                        <filter string="Tags" name="tag_ids" context="{'group_by':'tag_ids'}"/>

                </search>
            </field>
        </record>

        <record id="action_session_test" model="ir.actions.act_window">
            <field name="name">Session Test</field>
            <field name="res_model">session.test</field>
            <field name="view_mode">list,form</field>
        </record>

<!--        embedded action-->

        <record id="project_embedded_action_session_test" model="ir.embedded.actions">
            <field name="parent_res_model">project.project</field>
            <field name="sequence">100</field>
            <field name="name">Session tests</field>
            <field name="parent_action_id" ref="project.act_project_project_2_project_task_all"/>
            <field name="python_method">action_session_test_object</field>
            <field name="context">{"from_embedded_action": true}</field>
        </record>

        <menuitem id="session_test_sub_menu" action="action_session_test"
                  name="Session Test" sequence="2"
                  parent="project.menu_main_pm"/>
    </data>
</odoo>

