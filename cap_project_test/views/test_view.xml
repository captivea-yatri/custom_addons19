<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="test_tree_view" model="ir.ui.view">
            <field name="name">test.tree.view</field>
            <field name="model">test.test</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="template_test_id"/>
                    <field name="task_id"/>
                    <field name="project_domain_id"/>
                    <field name="project_id"/>
                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                    <field name="description" widget="html"/>
                    <field name="status_of_last_execution_test" class="text-center"/>
                    <field name="date_of_last_execution_test"/>
                    <field name="assigned_user_id"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="test_form_view" model="ir.ui.view">
            <field name="name">test.form.view</field>
            <field name="model">test.test</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True"/>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_execution_test_object"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-check-square-o icon">
                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_text">Execution</span>
                                    <span class="o_stat_text">Test</span>
                                </div>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1 class="d-flex flex-row">
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="template_test_id" options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="project_domain_id" readonly="True" options="{'no_open': True}"/>
                                <field name="project_id" readonly="True"/>
                                <field name="task_id" options="{'no_create': True, 'no_create_edit': True}" domain="[('project_id', '=', project_id)]"/>
                                <field name="tag_ids" widget="many2many_tags"
                                       options="{'no_create': True, 'no_create_edit': True,'color_field': 'color'}"/>
                            </group>
                            <group>
                                <field name="stage_id" options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="status_of_last_execution_test" readonly="True"/>
                                <field name="date_of_last_execution_test" readonly="True"/>
                                <field name="assigned_user_id" readonly="True"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="description" string="Description">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="test_search_view" model="ir.ui.view">
            <field name="name">test.search.view</field>
            <field name="model">test.test</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="template_test_id"/>
                    <field name="task_id"/>
                    <field name="project_domain_id"/>
                    <field name="project_id"/>
                    <field name="tag_ids"/>
                    <field name="status_of_last_execution_test"/>
                    <field name="date_of_last_execution_test"/>
                    <field name="assigned_user_id"/>
                    <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>

                        <filter string="Name" name="name" context="{'group_by':'name'}"/>
                        <filter string="Template Test" name="template_test_id"
                                context="{'group_by':'template_test_id'}"/>
                        <filter string="Task" name="task_id"
                                context="{'group_by':'task_id'}"/>
                        <filter string="Project Domain" name="project_domain_id"
                                context="{'group_by':'project_domain_id'}"/>
                        <filter string="Project" name="project_id"
                                context="{'group_by':'project_id'}"/>
                        <filter string="Tags" name="tag_ids"
                                context="{'group_by':'tag_ids'}"/>

                </search>
            </field>
        </record>

        <record id="action_test" model="ir.actions.act_window">
            <field name="name">Task Test</field>
            <field name="res_model">test.test</field>
            <field name="view_mode">list,form</field>
        </record>

<!--        embedded action-->

        <record id="project_embedded_action_task_tests" model="ir.embedded.actions">
            <field name="parent_res_model">project.project</field>
            <field name="sequence">100</field>
            <field name="name">Task tests</field>
            <field name="parent_action_id" ref="project.act_project_project_2_project_task_all"/>
            <field name="python_method">action_test_object</field>
            <field name="context">{"from_embedded_action": true}</field>
        </record>

        <menuitem id="test_sub_menu" action="action_test"
                  name="Task Test"
                  parent="template_test_main_menu" sequence="3"/>
    </data>
</odoo>

