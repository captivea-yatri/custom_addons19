<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="execution_test_tree_view" model="ir.ui.view">
            <field name="name">execution.test.tree.view</field>
            <field name="model">execution.test</field>
            <field name="arch" type="xml">
                <list create="false">
                    <field name="session_test_id"/>
                    <field name="branch"/>
                    <field name="test_id"/>
                    <field name="project_id"/>
                    <field name="task_id"/>
                    <field name="phase_id"/>
                    <field name="domain_id"/>
                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                    <field name="date"/>
                    <field name="assigned_user_id"/>
                    <field name="status"/>
                </list>
            </field>
        </record>

        <record id="execution_test_form_view" model="ir.ui.view">
            <field name="name">execution.test.form.view</field>
            <field name="model">execution.test</field>
            <field name="arch" type="xml">
                <form create="false">
                    <header>
                        <field name="status" widget="statusbar"/>
                        <!--                        options="{'clickable': '1', 'fold_field': 'fold'}"-->
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="session_test_id" readonly="True"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="branch" readonly="True"/>
                                <field name="test_id" readonly="True"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="project_id" readonly="True"/>
                                <field name="task_id" readonly="True"/>
                            </group>
                            <group>
                                <field name="assigned_user_id" readonly="True"/>
                                <field name="phase_id" readonly="True"/>
                                <field name="domain_id" readonly="True" options="{'no_open': True}"/>
                                <field name="tag_ids" widget="many2many_tags" readonly="True" options="{'color_field': 'color'}"/>
                                <field name="date" readonly="True"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="execution_test_kanban_view" model="ir.ui.view">
            <field name="name">execution.test.kanban.view</field>
            <field name="model">execution.test</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" create="false" edit="false">
                    <field name="session_test_id"/>
                    <field name="branch"/>
                    <field name="test_id"/>
                    <field name="project_id"/>
                    <field name="task_id"/>
                    <field name="phase_id"/>
                    <field name="domain_id"/>
                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                    <field name="date"/>
                    <field name="assigned_user_id"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <field name="status"/>
                                    <div>
                                        Session:
                                        <field name="session_test_id"/>
                                    </div>
                                    <div>
                                        Test:
                                        <field name="test_id"/>
                                    </div>
                                    <div>
                                        Date:
                                        <field name="date"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="execution_test_search_view" model="ir.ui.view">
            <field name="name">execution.test.search.view</field>
            <field name="model">execution.test</field>
            <field name="arch" type="xml">
                <search>
                    <field name="session_test_id"/>
                    <field name="branch"/>
                    <field name="test_id"/>
                    <field name="project_id"/>
                    <field name="task_id"/>
                    <field name="phase_id"/>
                    <field name="domain_id"/>
                    <field name="date"/>
                    <field name="assigned_user_id"/>
                    <field name="status"/>
                    <field name="tag_ids"/>

                        <filter string="Date" name="date" context="{'group_by':'date'}"/>
                        <filter string="Assigned User" name="assigned_user_id"
                                context="{'group_by':'assigned_user_id'}"/>
                        <filter string="Project" name="project_id"
                                context="{'group_by':'project_id'}"/>
                        <filter string="Phase" name="phase_id"
                                context="{'group_by':'phase_id'}"/>
                        <filter string="Domain" name="domain_id"
                                context="{'group_by':'domain_id'}"/>
                        <filter string="Tags" name="tag_ids" context="{'group_by':'tag_ids'}"/>
                        <filter string="Task" name="task_id"
                                context="{'group_by':'task_id'}"/>
                        <filter string="Status" name="status"
                                context="{'group_by':'status'}"/>
                        <filter string="Session" name="session_test_id"
                                context="{'group_by':'session_test_id'}"/>
                        <filter string="Branch" name="branch"
                                context="{'group_by':'branch'}"/>
                        <filter string="Test" name="test_id"
                                context="{'group_by':'test_id'}"/>

                </search>
            </field>
        </record>

        <record id="action_execution_test" model="ir.actions.act_window">
            <field name="name">Execution Test</field>
            <field name="res_model">execution.test</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="view_ids"
                   eval="[(5, 0, 0),
                          (0, 0, {'view_mode': 'list', 'view_id': ref('execution_test_tree_view')}),
                          (0, 0, {'view_mode': 'form', 'view_id': ref('execution_test_form_view')})]"/>
        </record>

        <menuitem id="execution_test_sub_menu" action="action_execution_test"
                  name="Execution Test" sequence="1"
                  parent="template_test_main_menu"/>
    </data>
</odoo>
