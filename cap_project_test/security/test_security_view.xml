<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <record model="ir.rule" id="project_test_rule">
            <field name="name">Project/Test: multi-company</field>
            <field name="model_id" ref="model_test_test"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[('project_id.company_id', 'in', company_ids)]</field>
        </record>
