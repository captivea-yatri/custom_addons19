<odoo>
    <data>
        <record id="view_move_form_inherit_lot" model="ir.ui.view">
            <field name="name">account.move.form.inherit.lot</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">

               <!-- Add to invoice line tree view -->
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_id']" position="after">
                    <field name="lot_id" string="Lot/Serial Number"/>
                </xpath>


            </field>
        </record>
    </data>
</odoo>
