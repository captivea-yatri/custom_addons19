<!--          "res_model": self._name,-->
<!--        }-->
<!--      </field>-->
<!--    </record>-->

<record model="ir.actions.server" id="product_currency.action_server">
    <field name="name">product_currency server</field>
    <field name="model_id" ref="model_product_currency_product_currency"/>
    <field name="state">code</field>
    <field name="code">
if record:
    action = {
        "type": "ir.actions.act_window",
        "view_mode": "form",
        "res_model": "product_currency.product_currency",
        "res_id": record.id,
        "target": "current",
    }
else:
    action = {
        "type": "ir.actions.act_window",
        "view_mode": "list,form",
        "res_model": "product_currency.product_currency",
        "target": "current",
    }

    </field>
</record>


    <!-- Top menu item -->

    <menuitem name="product_currency" id="product_currency.menu_root"/>

    <!-- menu categories -->

    <menuitem name="Menu 1" id="product_currency.menu_1" parent="product_currency.menu_root"/>
    <menuitem name="Menu 2" id="product_currency.menu_2" parent="product_currency.menu_root"/>

    <!-- actions -->

    <menuitem name="List" id="product_currency.menu_1_list" parent="product_currency.menu_1"
              action="product_currency.action_window"/>
    <menuitem name="Server to list" id="product_currency" parent="product_currency.menu_2"
              action="product_currency.action_server"/>
  </data>
</odoo>