<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="cap_view_company_form_go_live" model="ir.ui.view">
        <field name="name">cap.view.company.form</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_info']/group[1]" position="inside">
                <group string="Project Go Live Validation">
                    <field name="glcr_steps"/>
                    <field name="glcr_s2_validater"
                           invisible="glcr_steps != '2'" required="glcr_steps =='2'" options="{'no_create':True}"
                           domain="[('share','=', False)]"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>