<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_glive_change_request_form" model="ir.ui.view">
            <field name="name">glive.change.request.form</field>
            <field name="model">glive.change.request</field>
            <field name="arch" type="xml">
                <form string="Change Request">
                    <header>
                        <field name="state" widget="statusbar"/>

<!--                        todo:check when cap_offer module migrate-->
<!--                        <button name="approve_manager_approval"-->
<!--                                invisible="state != 'requested' or glcr_steps == '1'"-->
<!--                                string="Approve" type="object" class="btn-primary"/>-->

<!--                        <button name="approve_manager_approval"-->
<!--                                invisible="state != 'requested' or glcr_steps == '2'"-->
<!--                                string="Validate" type="object" class="btn-primary"/>-->

                        <button name="direction_applied_manager_approval"
                                invisible="state != 'manager_approved' or glcr_steps != '2'"
                                string="Validate" type="object" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="project_id"
                                       readonly="state != 'requested'" required="1"/>
                                <field name="reason" readonly="state != 'requested'" required="1"/>
                                <field name="glcr_steps" invisible="1"/>
                            </group>
                            <group>
                                <field name="current_go_live_date" readonly="1" force_save="1"/>
                                <field name="new_go_live_date" readonly="state != 'requested'" required="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="proof" readonly="state != 'requested'" required="1"/>
                        </group>
                    </sheet>
                    <div class="o_attachment_preview"/>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="glive_change_request_view_tree" model="ir.ui.view">
            <field name="name">glive.change.request.tree</field>
            <field name="model">glive.change.request</field>
            <field name="arch" type="xml">
                <list>
                    <field name="project_id"/>
                    <field name="current_go_live_date"/>
                    <field name="new_go_live_date"/>
                    <field name="reason"/>
                </list>
            </field>
        </record>

        <record id="action_view_glive_change_request" model="ir.actions.act_window">
            <field name="name">Go Live Change Request</field>
            <field name="res_model">glive.change.request</field>
            <field name="view_mode">list,form</field>
        </record>

<!--        embedded action-->

        <record id="project_embedded_action_go_live_cr" model="ir.embedded.actions">
            <field name="parent_res_model">project.project</field>
            <field name="sequence">100</field>
            <field name="name">Go live change request</field>
            <field name="parent_action_id" ref="project.act_project_project_2_project_task_all"/>
            <field name="python_method">action_view_go_live_cr</field>
            <field name="context">{"from_embedded_action": true}</field>
        </record>

        <menuitem name="Go Live Change Request" id="menu_glive_change_request" parent="project.menu_main_pm"
                  action="action_view_glive_change_request" sequence="5"
                  groups="base.group_no_one,project.group_project_user"/>

    </data>
</odoo>
