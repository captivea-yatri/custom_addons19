<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_account_move_customer_seniority_form">
        <field name="name">account.move.customer.seniority.days.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='sale_info_group']"
                   position="inside">
                <label for="customer_seniority_days"/>
                <div>
                    <field name="customer_seniority_days" class="oe_inline" readonly="1"/> Days
                </div>
                <field name="customer_seniority_type" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
