<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_sale_order_maintenance_support_form" model="ir.ui.view" >
            <field name="name">sale.order.form.cap.partner</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='partner_details']/field[@name='partner_shipping_id']"
                       position="after">
                    <field name="display_maintenance_support_terms"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
