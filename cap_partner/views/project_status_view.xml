<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <!--<=========================Project Status Tree View============================================>-->
        <record id="project_status_view_tree" model="ir.ui.view">
            <field name="name">project.status.view.tree</field>
            <field name="model">project.status</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                </list>
            </field>
        </record>
        <!--<=========================Project Status Form View============================================>-->
        <record id="project_status_view_from" model="ir.ui.view">
            <field name="name">project.status.view.from</field>
            <field name="model">project.status</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group name="name">
                                <field name="name"/>
                            </group>
                            <group name="code">
                                <field name="code"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="project_status_view_action">
            <field name="name">Project Status</field>
            <field name="res_model">project.status</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_project_status_main" name="Project Status" parent="project.menu_project_config"
                  action="project_status_view_action"/>
    </data>
</odoo>
