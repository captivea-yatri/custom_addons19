<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="mark_customer_lost_wizard_form" model="ir.ui.view">
        <field name="name">mark.customer.lost.form</field>
        <field name="model">mark.customer.lost</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="partner_id" readonly="1" force_save="1"/>
                        <field name="lost_date" required="1"/>
                    </group>
                    <group>
                        <field name="lost_reason" required="1"/>
                    </group>
                </group>
                <footer>
                    <button string="Validate" name="do_validate" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="mark_customer_lost_wizard_action" model="ir.actions.act_window">
        <field name="name">Mark Customer As Lost</field>
        <field name="res_model">mark.customer.lost</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="cap_partner.mark_customer_lost_wizard_form"/>
        <field name="target">new</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_view_types">form</field>
    </record>
</odoo>