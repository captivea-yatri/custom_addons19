<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="automation_remove_roll_project" model="ir.cron">
            <field name="name">Automatically Remove Users from Project Role</field>
            <field name="model_id" ref="model_project_project"/>
            <field name="state">code</field>
            <field name="code">model.automatic_remove_role_project()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now()  + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>

        <record id="automation_check_followup_status" model="ir.cron">
            <field name="name">Check Customer Follow-up Status</field>
            <field name="model_id" ref="model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model._check_followup_status()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>
    </data>
</odoo>
