<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="default_domain_tree_view" model="ir.ui.view">
            <field name="name">default.domain.tree.view</field>
            <field name="model">default.domain</field>
            <field name="arch" type="xml">
                <list editable="top">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="used_on_contact"/>
                    <field name="active" invisible="1"/>
                    <field name="is_an_app"/>
                    <field name="all_phases"/>
                </list>
            </field>
        </record>

        <record id="action_default_domain" model="ir.actions.act_window">
            <field name="name">Default Domain</field>
            <field name="res_model">default.domain</field>
            <field name="view_mode">list</field>
        </record>

        <menuitem id="default_domain_menu" action="action_default_domain" name="Default Domain"
                  parent="project.menu_project_config"/>
    </data>
</odoo>
