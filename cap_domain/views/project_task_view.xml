<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="project_task_extended_view" model="ir.ui.view">
            <field name="name">project.task.extended.view</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_form2"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet/group/group/field[@name='project_id']" position="after">
                    <field name="code" invisible="1"/>
                    <field name="create_date" invisible="1"/>
                    <field name="project_domain_id" invisible="1"/>
                    <field name="default_domain_id"
                           options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                           context="{'project_id': project_id}"
                           required="code not in ['internal', 'internal_p2p3'] and (not create_date or create_date >= '2023-10-01 00:00:00')"/>
                    <field name="default_domain_ids" invisible="1"/>
                    <field name="default_phase_id" context="{'project_id': project_id}"
                           options="{'no_create': True, 'no_create_edit': True}"
                           required="code not in ['internal', 'internal_p2p3'] and (not create_date or create_date >= '2023-10-01 00:00:00')"/>
                </xpath>
                <xpath expr="//field[@name='active']" position="before">
                    <field name="role_id" options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="user_ids" position="move"/>
                    <field name="tag_ids" position="move"/>
                    <label for="planned_date_begin" string="Planned Date"/>
                    <div name="dates" class="o_row">
                        <field name="planned_date_begin" widget="daterange"
                               options="{'end_date_field': 'date_deadline'}"/>
                        <field name="recurring_task" nolabel="1" class="ms-0" style="width: fit-content;"
                               widget="boolean_icon" options="{'icon': 'fa-repeat'}" invisible="not active or parent_id"
                               groups="project.group_project_recurring_tasks"/>
                    </div>
                </xpath>
                <xpath expr="//field[@name='child_ids']/list/field[@name='stage_id']" position="after">
                    <field name="default_domain_ids" invisible="1"/>
                     <field name="default_phase_id"  domain="[('project_id', '=', project_id)]" optional="hide"/>
                    <field name="default_domain_id" optional="hide"/>
                </xpath>
            </field>
        </record>

        <record id="project_sharing_inherit_project_task_view_search_domain" model="ir.ui.view">
            <field name="name">project.task.search.inherit</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_search_form_project_base"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='date_deadline']" position="after">
                    <filter name="default_domain_id" string="Domain"
                            context="{'group_by': 'default_domain_id'}"/>
                    <filter name="default_phase_id" string="Phase"
                            context="{'group_by': 'default_phase_id'}"/>
                    <filter name="role_id" string="Role"
                            context="{'group_by': 'role_id'}"/>
                </xpath>
                <xpath expr="//filter[@name='closed_on']" position="after">
                    <separator/>
                    <filter name="parent_tasks" string="Parent Tasks"
                            domain="[('parent_id','=',False)]"/>
                </xpath>
                <xpath expr="//field[@name='name']" position="before">
                    <field name="id"/>
                </xpath>
            </field>
        </record>

        <record id="project_task_view_search_domain" model="ir.ui.view">
            <field name="name">project.task.search.inherit</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_search_form"/>
            <field name="arch" type="xml">
                <field name="tag_ids"/>
                <xpath expr="//search" position="inside">
                    <field name="default_phase_id" string="Phase"/>
                    <field name="default_domain_id" string="Domain"/>
                </xpath>
                <xpath expr="//filter[@name='date_deadline']" position="after">
                    <filter name="default_domain_id" string="Domain"
                            context="{'group_by': 'default_domain_id'}"/>
                    <filter name="default_phase_id" string="Phase"
                            context="{'group_by': 'default_phase_id'}"/>
                    <filter name="role_id" string="Role"
                            context="{'group_by': 'role_id'}"/>
                    <filter string="Tags" name="tag_ids"
                                context="{'group_by':'tag_ids'}"/>
                </xpath>
            </field>
        </record>

        <record id="view_task_tree2_phase_domain" model="ir.ui.view">
            <field name="name">project.task.tree</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_tree2"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='stage_id']" position="after">
                    <field name="default_phase_id" optional="hide" context="{'project_id': project_id}"
                           domain="[('project_id', '=', project_id)]"
                           options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="project_domain_id" optional="hide"/>
                </xpath>
                <xpath expr="//field[@name='project_id']" position="before">
                    <field name="role_id" optional="hide"  options="{'no_create': True, 'no_create_edit': True}"/>
                </xpath>
            </field>
        </record>

        <record id="cap_domain_project_sharing_project_task_view_kanban_inherit" model="ir.ui.view">
            <field name="name">project.task.tree</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.project_sharing_project_task_view_kanban"/>
            <field name="arch" type="xml">
                <xpath expr="//kanban[1]" position="attributes">
                    <attribute name="quick_create">false</attribute>
                </xpath>
                <xpath expr="//kanban[1]/templates[1]/t[2]/div/field[@name='partner_id']"
                       position="after">
                    <field name="id" display="full"/>
                </xpath>
                <xpath expr="//t[@t-name='menu']" position="replace">
                    <t t-name="menu" t-if="!selection_mode">
                        <a t-if="widget.editable" role="menuitem" type="edit" class="dropdown-item">Edit</a>
<!--                        <div role="separator" class="dropdown-divider"/>-->
<!--                        <field name="color" widget="kanban_color_picker"/>-->
                    </t>
                </xpath>
            </field>
        </record>

        <record id="project_view_task_kanban_quick_create" model="ir.ui.view">
            <field name="name">project.view.task.kanban.quick.create</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_kanban"/>
            <field name="arch" type="xml">
                <xpath expr="//kanban[1]" position="attributes">
                    <attribute name="quick_create">false</attribute>
                </xpath>
            </field>
        </record>

