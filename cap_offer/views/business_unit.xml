<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="business_unit_tree_view" model="ir.ui.view">
        <field name="name">business.unit</field>
        <field name="model">business.unit</field>
        <field name="arch" type="xml">
            <list  editable="top">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="business_unit_form_view" model="ir.ui.view">
        <field name="name">business.unit</field>
        <field name="model">business.unit</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="business_unit_search_view" model="ir.ui.view">
            <field name="name">business.unit.search.view</field>
            <field name="model">business.unit</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
    </record>

    <record id="action_business_unit" model="ir.actions.act_window">
        <field name="name">Business Unit</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">business.unit</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_business_unit" parent="sale.menu_sales_config"
              action="action_business_unit" name="Business Unit"/>
</odoo>