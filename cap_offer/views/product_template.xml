<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_inherit_view_id_01" model="ir.ui.view">
        <field name="name">product.template.inherit.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Offer Details">
                    <group>
                        <group>
<!--                            <field name="offer_id" options='{"no_create": True, "no_edit": True}'/>-->
                            <field name="offer_ids" options='{"no_create": True, "no_edit": True}' widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="default_domain_ids" widget="many2many_tags"
                                   options='{"no_create": True, "no_edit": True}'/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
