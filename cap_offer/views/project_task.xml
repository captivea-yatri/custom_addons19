<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="project_task_view_inherit_view_id_002" model="ir.ui.view">
        <field name="name">project.task.inherit.view</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="hr_timesheet.view_task_form2_inherited"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='milestone_id']" position="after">
                <field name="offer_id"/>
                <field name="restrict_time" invisible="1"/>
            </xpath>
        </field>
    </record>


    <record id="project_task_view_form_inherit_sale_timesheet_cap_offer" model="ir.ui.view">
        <field name="name">project.task.form.view.form.inherit.sale.timesheet.cap_offer</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="sale_timesheet.project_task_view_form_inherit_sale_timesheet"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='timesheet_ids']/list/field[@name='so_line']" position="replace">
                <field name="so_line" widget="so_line_field" groups="!sales_team.group_sale_salesman,!base.group_system"
                       column_invisible="not parent.allow_billable"
                       readonly="parent.restrict_time == True"
                       context="{'with_remaining_hours': True, 'with_price_unit': True}"
                       options="{'no_create': True, 'no_open': True}"
                       domain="[('is_service', '=', True), ('order_partner_id', 'child_of', parent.partner_id), ('is_expense', '=', False), ('state', '=', 'sale')]"
                       optional="hide"/>
            </xpath>
        </field>
    </record>


