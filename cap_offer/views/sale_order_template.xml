<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="sale_order_template_inherited_view" model="ir.ui.view">
        <field name="name">sale.order.template.inherited</field>
        <field name="model">sale.order.template</field>
        <field name="inherit_id" ref="sale_management.sale_order_template_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="offer_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_template_inherited_view_form" model="ir.ui.view">
        <field name="name">sale.order.template.inherited.form</field>
        <field name="model">sale.order.template</field>
        <field name="inherit_id" ref="sale_management.sale_order_template_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='plan_id']" position="after">
                <field name="offer_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>
</odoo>