<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="business_localisation_tree_view" model="ir.ui.view">
        <field name="name">business.localisation</field>
        <field name="model">business.localisation</field>
        <field name="arch" type="xml">
            <list  editable="top">
                <field name="name"/>
                <field name="pricelist_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="business_localisation_form_view" model="ir.ui.view">
        <field name="name">business.localisation</field>
        <field name="model">business.localisation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="pricelist_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="business_localisation_search_view" model="ir.ui.view">
            <field name="name">business.localisation.search.view</field>
            <field name="model">business.localisation</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="pricelist_ids" widget="many2many_tags"/>
                </search>
            </field>
    </record>

    <record id="action_business_localisation" model="ir.actions.act_window">
        <field name="name">Business Localisation</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">business.localisation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_business_localisation" parent="sale.menu_sales_config"
              action="action_business_localisation" name="Business Localisation"/>
</odoo>