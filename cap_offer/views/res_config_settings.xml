<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="inherit_sale_res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.inherit.sale.view</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <div id="languages" position="after">
                    <div id="allow_offer_date_id">
                        <h2>Offer Behavior Implementation:</h2>
                        <div class="row mt16 o_settings_container" name="offer_setting_container">
                            <div class="col-12 col-lg-6 o_setting_box" id="offer_behavior_implementation">
                                <label for="allow_offer_date"/>
                                <field name="allow_offer_date"/>
                            </div>
                        </div>
                    </div>
                </div>
            </field>
        </record>
    </data>
</odoo>
