<!--           Scheduled action which will change status of request to Renewal after 1 year-->
        <record id="ir_cron_data_emp_access" model="ir.cron">
            <field name="name">Employee Request Access</field>
            <field name="model_id" ref="model_emp_access_request"/>
            <field name="state">code</field>
            <field name="code">model._emp_access_request_check()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name='interval_number'>1</field>
            <field name='interval_type'>months</field>
        </record>

        <!--           Scheduled action which will change status of Renewal to Rejected after 10 days-->
        <record id="ir_cron_data_requests_renewal" model="ir.cron">
            <field name="name">Reject Access Requests</field>
            <field name="model_id" ref="model_emp_access_request"/>
            <field name="state">code</field>
            <field name="code">
ten_days_ago = datetime.date.today() + dateutil.relativedelta.relativedelta(days=-10)
renewal_records = model.search([('state', '=', 'Renewal'), ('access_request_date', '&lt;=', ten_days_ago)], limit=100)
for record in renewal_records:
    record.button_rejected()
            </field>
            <field name="user_id" ref="base.user_root"/>
            <field name='interval_number'>1</field>
            <field name='interval_type'>days</field>
        </record>

