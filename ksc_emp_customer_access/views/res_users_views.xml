<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <record id="users_extended_view_form_extended" model="ir.ui.view">
    <field name="name">users.extended.view.form.extended</field>
    <field name="model">res.users</field>
    <field name="inherit_id" ref="base.view_users_form"/>
    <field name="arch" type="xml">

        <!-- Replace the inner oe_title div inside the d-flex gap-3 container -->
        <xpath expr="//div[@class='d-flex gap-3']/div[contains(@class, 'oe_title')]" position="replace">
            <div class="oe_title">
                <label for="partner_id"/>
                <div class="d-flex">
                    <h2>
                        <field name="partner_id" placeholder="e.g. John Doe" required="1"/>
                    </h2>
                    <button name="link_partners"
                            class="w-0"
                            type="object"
                            icon="fa-refresh"
                            help="Grant Internal User Contact Access!"/>
                </div>
            </div>
        </xpath>

    </field>
</record>
</odoo>
