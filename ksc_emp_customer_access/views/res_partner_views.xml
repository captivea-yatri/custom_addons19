<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="contacts_extended_view_form_extended" model="ir.ui.view">
        <field name="name">contacts.extended.view.form.extended</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="/form/sheet/group/group/div[2]" position="after">
    <field name="accessible_user_ids"/>
  </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="view_access_req"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-universal-access"
                        invisible="not is_company"
                        groups="base.group_user">
<!--                        groups="access_rights_management.group_access_request">-->
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Access</span>
                        <span class="o_stat_text">Requests</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <record id="res_partner_view_form_inherit_mail_roles" model="ir.ui.view">
        <field name="name">res.partner.view.form.inherit.mail.roles</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="mail.res_partner_view_form_inherit_mail"/>
        <field name="arch" type="xml">
            <xpath expr="//chatter" position="after">
                <field name="is_access" invisible="1"/>
                <chatter invisible="not is_access" groups="access_rights_management.role_operation_on_boarder,access_rights_management.role_operation,access_rights_management.role_team_manager,access_rights_management.role_team_director"/>
            </xpath>
            <xpath expr="//chatter" position="replace">
                <chatter groups="!access_rights_management.role_operation_on_boarder,!access_rights_management.role_operation,!access_rights_management.role_team_manager,!access_rights_management.role_team_director"/>
            </xpath>
        </field>
    </record>

