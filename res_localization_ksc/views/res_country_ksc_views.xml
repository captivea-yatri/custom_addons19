<odoo>
    <record id="view_country_ksc_list" model="ir.ui.view">
        <field name="name">res.country.ksc.list</field>
        <field name="model">res.country.ksc</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="view_country_ksc_form" model="ir.ui.view">
        <field name="name">res.country.ksc.form</field>
        <field name="model">res.country.ksc</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="state_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_country_ksc" model="ir.actions.act_window">
        <field name="name">Countries</field>
        <field name="res_model">res.country.ksc</field>
        <field name="view_mode">list,form</field>
    </record>
   <menuitem id="Localization" name="Localization"/>
    <menuitem id="country_child" name="Country" parent="Localization" action="action_country_ksc"/>
</odoo>
