<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="project_planning_form_view" model="ir.ui.view">
        <field name="name">project.planning.form.view</field>
        <field name="model">project.planning.wizard</field>
        <field name="arch" type="xml">
            <form string="Phase">
                <group>
                    <field name="phase_id" context="{'project_id': project_id}"
                           domain="[('project_id', '=', project_id)]"
                           options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="project_id" invisible="1"/>
                </group>
                <group>
                    <group>
                        <field name="planning_start_date"/>
                    </group>
                    <group>
                        <field name="weekly_capacity"/>
                    </group>
                </group>
                <footer>
                    <button name="calculate_planning_hours" string="Submit" type="object"
                            class="btn-primary"/>
                    <button special="cancel" data-hotkey="z" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_project_planning_wizard" model="ir.actions.act_window">
        <field name="name">Project Planning</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">project.planning.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="project_planning_form_view"/>
        <field name="target">new</field>
    </record>

</odoo>
