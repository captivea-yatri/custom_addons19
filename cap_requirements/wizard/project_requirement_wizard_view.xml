<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="create_project_requirement_form_view" model="ir.ui.view">
        <field name="name">project.requirement.wizard</field>
        <field name="model">project.requirement.wizard</field>
        <field name="arch" type="xml">
            <form string="Phase">
                <group class="oe_title">
                    <field name="phase_id" context="{'project_id': project_id}"
                           domain="[('project_id', '=', project_id)]"
                           options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="project_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_create_task_from_project" string="Create Task" type="object"
                            class="btn-primary"/>
                    <button special="cancel" data-hotkey="z" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_create_project_requirement" model="ir.actions.act_window">
        <field name="name">Create Project Requirement</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">project.requirement.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="create_project_requirement_form_view"/>
        <field name="target">new</field>
    </record>

</odoo>
