<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="project_task_inherit_view" model="ir.ui.view">
            <field name="name">project.task.inherit.view</field>
            <field name="model">project.task</field>
            <field name="priority">100</field>
            <field name="inherit_id" ref="project.view_task_form2"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='description']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//page[@name='description_page']" position="inside">
                    <div class="oe_title">
                        <group>
                            <field name="description" placeholder="Task Description....." nolabel="1" colspan="2"/>
                        </group>
                    </div>
                </xpath>
                <xpath expr="//notebook" position="inside">
                    <page name="help" string="Help">
                        <div class="oe_title">
                            <group>
                                <field name="help" readonly="True"/>
                            </group>
                        </div>
                    </page>
                </xpath>
                <xpath expr="//page[@name='extra_info']/group[1]/group[1]//field[@name='parent_id']" position="attributes">
                    <attribute name="domain">[('default_phase_id','=',default_phase_id),('default_domain_id','=',default_domain_id),('project_id','=',project_id),('id','!=',id),
('active','=',True)]</attribute>
                    <attribute name="context">{'default_project_id': project_id,'default_default_domain_id': default_domain_id,'default_default_phase_id': default_phase_id}</attribute>
                </xpath>
                <xpath expr="//page[@name='sub_tasks_page']//field[@name='child_ids']" position="attributes">
                    <attribute name="domain">[('default_phase_id','=',default_phase_id),('default_domain_id','=',default_domain_id),('project_id','=',project_id),('id','!=',id),('id','!=',parent_id),
('active','=',True)]</attribute>
                    <attribute name="context">{'default_project_id': project_id,'default_default_domain_id': default_domain_id,'default_default_phase_id': default_phase_id, 'default_parent_id':id}</attribute>
                </xpath>
            </field>
        </record>

        <record id="cap_domain_inherited_project_task_extended_view" model="ir.ui.view">
            <field name="name">project.task.inherit.view</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="cap_domain.project_task_extended_view"/>
            <field name="arch" type="xml">
                <field name="default_phase_id" position="after">
                    <field name="project_requirement_id" string="Project Requirement"
                           class="oe_highlight" options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="parent_id"
                            domain="[('default_phase_id','=',default_phase_id),('default_domain_id','=',default_domain_id),('project_id','=',project_id),'!',('id','child_of',id),('active', '=',
True)]"
                            context="{'default_project_id': project_id,'default_default_domain_id': default_domain_id,'default_default_phase_id': default_phase_id}"/>
                </field>
            </field>
        </record>

        <record id="project_task_view_search_domain_inherit" model="ir.ui.view">
            <field name="name">project.task.search.inherit</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_search_form_base"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='open_tasks']" position="after">
            <separator/>
            <filter string="Functional Requirement" name="project_requirement_id_set"
                    domain="['|','|',('project_requirement_id','=',False),
                              ('project_requirement_id.template_requirements_id','=',False),
                              ('project_requirement_id.template_requirements_id.all_apps', '=', False)]"/>
            <separator/>
        </xpath>
            </field>
        </record>
    </data>
</odoo>
