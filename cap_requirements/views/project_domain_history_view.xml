<odoo>
    <data>
        <record id="project_domain_history_tree_view" model="ir.ui.view">
            <field name="name">project.domain.history.tree.view</field>
            <field name="model">project.domain.history</field>
            <field name="arch" type="xml">
                <list edit="0">
                    <field name="name"/>
                    <field name="status"/>
                    <field name="estimated_time"/>
                    <field name="task_estimated_time"/>
                    <field name="task_passed_time"/>
                </list>
            </field>
        </record>

        <record id="project_domain_history_form_view" model="ir.ui.view">
            <field name="name">project.domain.history.form.view</field>
            <field name="model">project.domain.history</field>
            <field name="arch" type="xml">
                <form edit="0">
                    <header>
                        <field name="status" widget="statusbar" options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" required="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="default_domain_id"
                                       options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                                <field name="project_id" options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="phase_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="project_domain_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="KPI Based on requirements">
                                <group>
                                    <group>
                                        <field name="project_manager_time" widget="float_time"/>
                                        <field name="business_analyst_time" widget="float_time"/>
                                        <field name="configurator_time" widget="float_time"/>
                                        <field name="developer_time" widget="float_time"/>
                                        <field name="architect_time" widget="float_time"/>
                                    </group>
                                    <group>
                                        <field name="estimated_time" widget="float_time"/>
                                        <field name="core_time" widget="float_time"/>
                                        <field name="implementation_time" widget="float_time"/>
                                        <field name="local_time" widget="float_time"/>
                                        <field name="offshore_time" widget="float_time"/>
                                    </group>
                                </group>
                            </page>
                            <page string="KPI based on tasks">
                                <group>
                                    <group>
                                        <field name="task_estimated_time" widget="float_time"/>
                                    </group>
                                    <group>
                                        <field name="task_passed_time" widget="float_time"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!--<=========================================SEARCH VIEW================================================>-->
        <record id="project_domain_history_search_view" model="ir.ui.view">
            <field name="name">project.domain.history.search.view</field>
            <field name="model">project.domain.history</field>
            <field name="arch" type="xml">
                <search>
                    <field name="project_id"/>
                </search>
            </field>
        </record>
        <!--<=========================================SEARCH VIEW================================================>-->

        <record id="action_project_domain_history" model="ir.actions.act_window">
            <field name="name">Project Domain History</field>
            <field name="res_model">project.domain.history</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="project_domain_history_search_view"/>

        </record>

        <menuitem id="project_domain_history_ksc_menu" action="action_project_domain_history"
                  name="Project Domain History" parent="project.menu_project_config"/>
    </data>
</odoo>
