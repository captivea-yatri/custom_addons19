<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="cap_multi_company_link_view" model="ir.ui.view">
            <field name="name">cap.multi.company.link.view</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_shipping_id']" position="after">
                    <field name="is_internal_invoice" invisible="1"/>
                    <field name="inverse_move_type" invisible="1"/>
                    <field name="inter_comp_journal_entry_id" options="{'no_create': True, 'no_edit': True}"
                           domain="['|', ('company_id.partner_id','=',partner_id), ('company_id.partner_id.child_ids','=',partner_id),
                           ('inter_comp_journal_entry_id', '=', False), ('move_type','=', inverse_move_type)]"
                           invisible="is_internal_invoice == False"
                           readonly="move_type not in ['out_invoice', 'out_refund']"/>
                </xpath>
                <xpath expr="//header" position="inside">
                    <button name="generate_related_journal_entry" type="object"
                            invisible="is_internal_invoice == False or inter_comp_journal_entry_id != False or move_type not in ('out_invoice', 'out_refund')"
                            string="Generate the related journal entry"/>
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']" position="attributes">
                    <attribute name="readonly">state != 'draft' or (inter_comp_journal_entry_id != False and move_type in ['in_refund', 'in_invoice'])</attribute>
                </xpath>
                <xpath expr="//field[@name='line_ids']" position="attributes">
                    <attribute name="readonly">state != 'draft' or (inter_comp_journal_entry_id != False and move_type in ['in_refund', 'in_invoice'])</attribute>
                </xpath>
                <xpath expr="//group[@name='accounting_info_group']/field[@name='company_id']" position="attributes">
                    <attribute name="readonly">state != 'draft' or (inter_comp_journal_entry_id != False and move_type in ['in_refund', 'in_invoice'])</attribute>
                    <attribute name="invisible">move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund')</attribute>
                </xpath>
                <xpath expr="//group[@name='accounting_info_group']/field[@name='auto_post']" position="attributes">
                    <attribute name="readonly">inter_comp_journal_entry_id != False and (move_type in ['in_refund', 'in_invoice'] or state != 'draft')</attribute>
                    <attribute name="invisible">move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund')</attribute>
                </xpath>
                <xpath expr="//page[@name='other_info']" position="attributes">
                    <attribute name="readonly">inter_comp_journal_entry_id != False and move_type in ['in_refund', 'in_invoice']</attribute>
                    <attribute name="invisible">move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'entry', 'in_refund')</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="readonly">state != 'draft' or (inter_comp_journal_entry_id != False and move_type in ['in_refund', 'in_invoice'])</attribute>
                    <attribute name="invisible">move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')</attribute>
                </xpath>
                <xpath expr="//field[@name='name']" position="attributes">
                    <attribute name="readonly">state != 'draft'</attribute>
                </xpath>
                <xpath expr="//field[@name='invoice_date']" position="attributes">
                    <attribute name="readonly">state != 'draft' or (inter_comp_journal_entry_id != False and move_type in ['in_refund', 'in_invoice'])</attribute>
                </xpath>
                <xpath expr="//group[@id='header_right_group']/field[@name='date']" position="attributes">
                    <attribute name="readonly">inter_comp_journal_entry_id != False and (move_type in ['in_refund','in_invoice'] or state != 'draft')</attribute>
                    <attribute name="invisible">move_type in ('out_invoice', 'out_refund', 'out_receipt') and quick_edit_mode == False</attribute>
                </xpath>
                <xpath expr="//field[@name='payment_reference']" position="attributes">
                    <attribute name="readonly">inter_comp_journal_entry_id != False and move_type in ['in_refund','in_invoice']</attribute>
                    <attribute name="invisible">move_type not in ('out_invoice', 'out_refund',
                        'in_invoice', 'in_refund', 'out_receipt','in_receipt')</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_bank_id']" position="attributes">
                    <attribute name="readonly">inter_comp_journal_entry_id != False and (state != 'draft' or move_type in ['in_refund','in_invoice'])</attribute>
                    <attribute name="invisible">move_type not in ('in_invoice', 'in_refund', 'in_receipt')</attribute>
                </xpath>
                <xpath expr="//field[@name='invoice_date_due']" position="attributes">
                    <attribute name="readonly">inter_comp_journal_entry_id != False and move_type in ['in_refund','in_invoice']</attribute>
                    <attribute name="invisible">invoice_payment_term_id != False</attribute>
                </xpath>
                <xpath expr="//div[@name='journal_div']/field[@name='journal_id']" position="attributes">
                    <attribute name="readonly">state != 'draft' or (inter_comp_journal_entry_id != False and (posted_before == True or move_type in ['in_refund','in_invoice']))</attribute>
                </xpath>
               <xpath expr="//div[@name='currency_div']//field[@name='currency_id']" position="attributes">
    <attribute name="readonly">
        inter_comp_journal_entry_id != False and (state != 'draft' or move_type in ['in_refund','in_invoice'])
    </attribute>
    <attribute name="invisible">move_type == 'entry'</attribute>
</xpath>

                <xpath expr="//group[@id='header_left_group']/field[@name='ref'][1]" position="attributes">
                    <attribute name="readonly">inter_comp_journal_entry_id != False and move_type in ['in_refund','in_invoice']</attribute>
                    <attribute name="invisible">move_type not in ('in_invoice', 'in_receipt', 'in_refund')</attribute>
                </xpath>
                <xpath expr="//field[@name='invoice_incoterm_id']" position="attributes">
                    <attribute name="readonly">inter_comp_journal_entry_id != False and move_type in ['in_refund','in_invoice']</attribute>
                </xpath>
                <xpath expr="//field[@name='fiscal_position_id']" position="attributes">
                    <attribute name="readonly">state != 'draft' or (inter_comp_journal_entry_id != False and move_type in ['in_refund','in_invoice'])</attribute>
                </xpath>
                <xpath expr="//field[@name='checked']" position="attributes">
                    <attribute name="readonly">inter_comp_journal_entry_id != False and move_type in ['in_refund','in_invoice']</attribute>
                    <attribute name="invisible">move_type != 'entry'</attribute>
                </xpath>
                <xpath expr="//button[@name='action_post'][2]" position="attributes">
                    <attribute name="invisible">(move_type in ['in_refund','in_invoice'] or state != 'draft') and (inter_comp_journal_entry_id != False or hide_post_button == True or move_type == 'entry' or display_inactive_currency_warning == True)</attribute>
                </xpath>
                <xpath expr="//button[@name='button_cancel'][2]" position="attributes">
                    <attribute name="invisible">(move_type not in ('out_invoice','out_refund') or state != 'draft') and (move_type in ('in_invoice','in_refund') or state != 'posted') and (inter_comp_journal_entry_id != False or (id == False or state != 'draft' or move_type == 'entry'))</attribute>
                </xpath>
                <xpath expr="//button[@name='button_draft']" position="attributes">
                    <attribute name="invisible">(move_type in ['in_refund','in_invoice'] or state == 'draft') and (inter_comp_journal_entry_id != False or show_reset_to_draft_button == False)</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reverse']" position="attributes">
                    <attribute name="invisible">(move_type in ['in_refund','in_invoice']) or (state != 'posted' and (inter_comp_journal_entry_id != False or (move_type not in ('out_invoice','in_invoice') or state != 'posted')))</attribute>
                </xpath>
<!--                <xpath expr="//button[@name='action_register_payment']" position="attributes">-->
<!--                    <attribute name="invisible">state != 'posted' or payment_state not in ('not_paid', 'partial') or move_type not in ('out_invoice', 'out_refund', 'in_invoice','in_refund', 'out_receipt', 'in_receipt')</attribute>-->
<!--                </xpath>-->
            </field>
        </record>

        <record id="cap_multi_company_purchase_vendor_bill_inherit_view" model="ir.ui.view">
            <field name="name">cap.multi.company.purchase.vendor.bill.inherit.view.readonly</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="purchase.view_move_form_inherit_purchase"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='purchase_vendor_bill_id']" position="attributes">
                    <attribute name="readonly">inter_comp_journal_entry_id != False or move_type == 'in_invoice'</attribute>
                    <attribute name="invisible">state != 'draft' or move_type != 'in_invoice'</attribute>
                </xpath>
            </field>
        </record>

        <record id="cap_multi_company_move_line_form_inherit_view_readonly" model="ir.ui.view">
            <field name="name">cap.multi.move.line.form.inherit.view.readonly</field>
            <field name="model">account.move.line</field>
            <field name="inherit_id" ref="account.view_move_line_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='information']" position="attributes">
                    <attribute name="readonly">1</attribute>
                </xpath>
            </field>
        </record>

        <record id="cap_multi_company_move_line_other_info_inherit_view_readonly" model="ir.ui.view">
            <field name="name">cap.multi.move.line.other.info.inherit.view.readonly</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="l10n_sg.view_invoice_form_l10n_sg"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='l10n_sg_permit_number']" position="attributes">
                    <attribute name="readonly">move_type in ['in_refund', 'in_invoice']</attribute>
                </xpath>
                <xpath expr="//field[@name='l10n_sg_permit_number_date']" position="attributes">
                    <attribute name="readonly">move_type in ['in_refund', 'in_invoice']</attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
