<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ksc_auto_invoice_view_company_form_inherit" model="ir.ui.view">
        <field name="name">ksc.auto.invoice.security.deposit</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="priority">16</field>
        <field name="arch" type="xml">
            <field name="currency_id" position="after">
                <field name="security_deposit_account_id"
                       domain="[('company_ids', 'in', [id])]"
                       string="Security Deposit Account"/>
            </field>
        </field>
    </record>
</odoo>
