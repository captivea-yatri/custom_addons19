<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="inherit_view_task_form2_inherited_riss_invoice" model="ir.ui.view">
            <field name="name">project_form_inherit</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="hr_timesheet.view_task_form2_inherited"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='timesheet_ids']/list/field[@name='unit_amount']" position="after">
                    <field name="riss_invoice_id" optional="hide" readonly="1"/>
                </xpath>
            </field>
        </record>
        <record id="timesheet_list_view_inherited_riss_group" model="ir.ui.view">
            <field name="name">account.analytic.line_tree_inherit</field>
            <field name="model">account.analytic.line</field>
            <field name="inherit_id" ref="hr_timesheet.timesheet_view_tree_user"/>
            <field name="arch" type="xml">
                <field name="unit_amount" position="after">
                    <field name="riss_invoice_id" optional="hide" readonly="1"/>
                </field>
            </field>
        </record>

        <record id="timesheet_view_search_domain_phase" model="ir.ui.view">
            <field name="name">account.analytic.line.search.inherit.domain.phase</field>
            <field name="model">account.analytic.line</field>
            <field name="inherit_id" ref="timesheet_grid.timesheet_view_search"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='my_tasks']" position="after">
                    <filter string="Invoiced For Group Riss" name="riss_invoice_id"
                            domain="[('riss_invoice_id', '!=', False)]"/>

                        <filter string="Invoiced For Group Riss" name="riss_invoice_id" domain="[]" context="{'group_by': 'riss_invoice_id'}"/>

                </xpath>
            </field>
        </record>

    </data>
</odoo>
