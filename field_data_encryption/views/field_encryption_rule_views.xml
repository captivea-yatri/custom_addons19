<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_field_encryption_rule_list" model="ir.ui.view">
        <field name="name">field.encryption.rule.list</field>
        <field name="model">field.encryption.rule</field>
        <field name="arch" type="xml">
            <list string="Field Encryption Rules">
                <field name="active" widget="boolean_toggle"/>
                <field name="model_id"/>
                <field name="field_id"/>
                <field name="field_type"/>
            </list>
        </field>
    </record>

    <record id="view_field_encryption_rule_form" model="ir.ui.view">
        <field name="name">field.encryption.rule.form</field>
        <field name="model">field.encryption.rule</field>
        <field name="arch" type="xml">
            <form string="Field Encryption Rule">
                <header>
                    <button
                        name="action_encrypt_existing_records"
                        type="object"
                        string="Encrypt Existing Records"
                        class="oe_highlight"
                    />
                    <field name="active" widget="boolean_toggle"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Configure <b>field_encryption_key</b> in odoo.conf before activating rules.
                        You can also use <b>field_encryption_key_${running_env}</b> when running_env is set.
                    </div>
                    <div class="alert alert-warning" role="alert">
                        Only stored Char, Text, and HTML fields are supported. Encrypted values are not searchable,
                        filterable, or groupable because Fernet encryption is non-deterministic.
                    </div>
                    <group>
                        <group>
                            <field name="model_id" options="{'no_create': True, 'no_open': True}"/>
                            <field
                                name="field_id"
                                domain="[('model_id', '=', model_id), ('store', '=', True), ('ttype', 'in', ['char', 'text', 'html'])]"
                                options="{'no_create': True, 'no_open': True}"
                            />
                        </group>
                        <group>
                            <field name="field_name" readonly="1"/>
                            <field name="field_type" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Optional admin note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_field_encryption_rule" model="ir.actions.act_window">
        <field name="name">Field Encryption Rules</field>
        <field name="res_model">field.encryption.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_field_encryption_root"
        name="Field Encryption"
        parent="base.menu_administration"
        sequence="90"
        groups="base.group_system"
    />

    <menuitem
        id="menu_field_encryption_rule"
        name="Rules"
        parent="menu_field_encryption_root"
        action="action_field_encryption_rule"
        sequence="10"
        groups="base.group_system"
    />
</odoo>
