<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="group_create_deferred_revenue_time_credit" model="res.groups">
        <field name="name">Allow To Create Time Credit Revenue</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>

        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_access_close_revenue_time_credit" model="res.groups">
        <field name="name">Close Time Credit Revenue</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>

        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="time_credit_multi_company_rule" model="ir.rule">
        <field name="name">Time Credit multi-company</field>
        <field ref="model_time_credit" name="model_id"/>
        <field eval="True" name="global"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

</odoo>
