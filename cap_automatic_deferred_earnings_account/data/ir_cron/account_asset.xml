<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--    Server action that compute revenue line for time credit    -->
        <record model="ir.actions.server" id="action_compute_dr_line_time_credit">
            <field name="name">Time Credit Compute Revenue Line(Add month line by project - Monthly on the 5th)</field>
            <field name="model_id" ref="cap_automatic_deferred_earnings_account.model_time_credit"/>
            <field name="binding_model_id" ref="cap_automatic_deferred_earnings_account.model_time_credit"/>
            <field name="binding_view_types">form</field>
            <field name="state">code</field>
            <field name="group_ids"
                   eval="[(4, ref('cap_automatic_deferred_earnings_account.group_create_deferred_revenue_time_credit'))]"/>
            <field name="code">
                for rec in records:
                    rec.compute_revenue_line_from_timesheet()
            </field>
        </record>

        <!--   Scheduled action that compute revenue line for time credit  -->
        <record id="cap_time_credit_cron" model="ir.cron">
            <field name="name">Time Credit Compute Credit Revenue Line(Add month line by project - Monthly on the 5th)</field>
            <field name="model_id" ref="cap_automatic_deferred_earnings_account.model_time_credit"/>
            <field name="state">code</field>
            <field name="code">model.with_context(automatic_entry=True).compute_revenue_line_from_timesheet()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <record id="cap_auto_reconcile_deferred_revenue_cron" model="ir.cron">
            <field name="name">Auto Reconcile Deferred Revenue/Deferred Expense</field>
            <field name="model_id" ref="account_asset.model_account_asset"/>
            <field name="state">code</field>
            <field name="code">model.automatically_reconcile_deferred_revenue_expense()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>

        <!--   Scheduled action to Calculate value left of previous fiscal period on time credit     -->
        <record id="cap_auto_calculate_value_left_of_the_previous_fiscal_period_time_credit_cron" model="ir.cron">
            <field name="name">Time Credit Auto Calculate Value Left Of The Previous Fiscal Period</field>
            <field name="model_id" ref="cap_automatic_deferred_earnings_account.model_time_credit"/>
            <field name="state">code</field>
            <field name="code">model.previous_fiscal_year()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>

        <!--   Server action to Calculate value left of previous fiscal period on time credit     -->
        <record model="ir.actions.server" id="cap_time_credit_auto_calculate_value_left_of_the_previous_fiscal_period_server_action">
            <field name="name">Time Credit Auto Calculate Value Left Of The Previous Fiscal Period</field>
            <field name="model_id" ref="cap_automatic_deferred_earnings_account.model_time_credit"/>
            <field name="binding_model_id" ref="cap_automatic_deferred_earnings_account.model_time_credit"/>
            <field name="binding_view_types">form</field>
            <field name="state">code</field>
            <field name="code">
                for rec in records:
                    rec.previous_fiscal_year()
            </field>
        </record>

        <record id="time_credit_lifetime_time_credit_cron" model="ir.cron">
            <field name="name">Credit Time Expiry Activity</field>
            <field name="model_id" ref="cap_automatic_deferred_earnings_account.model_time_credit"/>
            <field name="state">code</field>
            <field name="code">model.create_activity_for_expired_time_credits()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
        </record>
    </data>
</odoo>
