<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_order_form_line_domain_filter" model="ir.ui.view">
        <field name="name">sale.order.form</field>
        <field name="model">sale.order.line</field>
        <field name="priority">16</field>
        <field name="arch" type="xml">
            <form create="false">
                <group>
                    <field name="product_id" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="skip_product_id_domain" invisible="1"/>
<!--                    TODO: below filter column width check after database arrives-->
                    <field name="emp_filter_domain" widget="domain" readonly="False" force_save="True"
                           options="{'model': 'hr.employee', 'in_dialog': true}"
                           invisible="product_id == False"/>
                </group>
                <notebook>
                    <page string="Quota">
                        <field name="so_line_quota_ids" string="Quota">
                            <list editable="bottom" >
                                <field name="so_line_id" column_invisible="True"/>
                                <field name="employee_id" options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="hrs_qty" force_save="True"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="view_sale_order_deferred_earning_form">
        <field name="name">sale.order.deferred.earning.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="mode">extension</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_deferred_revenue_time_credit" type="object"
                        string="Time Credit Deferred Revenue" class="oe_stat_button" icon="fa-id-card-o"
                        invisible="count_time_credit == 0"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_close_deferred_revenue_time_credit" type="object"
                        string="Close Time Credit"
                        groups="cap_automatic_deferred_earnings_account.group_access_close_revenue_time_credit"
                        invisible="count_time_credit == 0 or revenue_closed_time_credit == True"/>
                <field name="revenue_closed_time_credit" invisible="1"/>
            </xpath>
            <field name="date_order" position="after">
                <field name="count_time_credit"/>
            </field>
            <xpath expr="//field[@name='order_line']/list/field[@name='collapse_composition']" position="after">
                <field name="skip_product_id_domain" column_invisible="True"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/form/group" position="inside">
                <group>
                        <field name="emp_filter_domain" widget="domain" options="{'model': 'hr.employee', 'in_dialog': true}"
                              readonly="False" force_save="True"
                              invisible="product_id == False" />
                </group>
            </xpath>
<!--            TODO : need to check it after solve the warning file-->
<!--            There is warning message from here when we try to lead this view.-->
<!--            Shows that need to apply string here.-->
            <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="before">
                <button name="open_sale_order_line_form_view" type="object" readonly="False" force_save="True"
                        title=" " icon="fa-filter icon" class="oe_edit_only"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="attributes">
                <attribute name="domain">[('sale_ok', '=', True), '|', ('company_id', '=', False), ('company_id', '=',
                    parent.company_id), ('id', 'not in', skip_product_id_domain)]
                </attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='display_type']" position="after">
                <field name="skip_product_id_domain" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='product_id']" position="attributes">
                <attribute name="domain">[('sale_ok', '=', True), '|', ('company_id', '=', False), ('company_id', '=',
                    parent.company_id), ('id', 'not in', skip_product_id_domain)]
                </attribute>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="deferred_revenue_status_time_credit"/>
            </xpath>
        </field>
    </record>
</odoo>
