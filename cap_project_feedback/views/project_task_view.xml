        <record id="cap_domain_project_task_project_sharing_view_form_inherited_03" model="ir.ui.view">
            <field name="name">project.project.task.view.form.inherit.form</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="hr_timesheet.view_task_form2_inherited"/>
            <field name="arch" type="xml">
                <xpath expr="//form[1]/sheet[1]/group[1]/group[2]/div[not(@name)][2]" position="after">
                    <div colspan="2">
                        <label for="estimate_time" string="Requirement Estimated Time" class="me-2"/>
                        <field name="estimate_time" class="o_field_float_time oe_inline ms-2" string="Requirement Estimated Time"/>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="cap_domain_project_task_project_sharing_view_tree_inherited_04" model="ir.ui.view">
            <field name="name">project.project.task.view.form.inherit.tree</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="hr_timesheet.view_task_tree2_inherited"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='allocated_hours']" position="after">
                    <field name="estimate_time" widget="timesheet_uom_no_toggle" sum="Requirement Estimated Time" optional="hide" string="Requirement Estimated Time"/>
                </xpath>
            </field>
        </record>

        <record id="cap_domain_project_task_project_sharing_view_tree_inherited_05" model="ir.ui.view">
            <field name="name">project.sharing.project.task.view.tree.inherit</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="cap_project_feedback.project_sharing_project_task_view_tree_custom"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="default_phase_id" string='Phase' readonly="1"/>
                    <field name="default_domain_id" class="o_task_user_field" string='Domain' readonly="1"/>
                    <field name="default_domain_ids" class="o_task_user_field" string="Default domain ids"
                           column_invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
