<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="project_project_account_inherit_view_id" model="ir.ui.view">
        <field name="name">project.project.account.inherit.view.id</field>
        <field name="model">project.project</field>
        <field name="priority">18</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        type="object" name="action_feedback" icon="fa-bullseye"
                        string="Feedback"/>
<!--                 context="{'default_project_id': active_id}"-->
            </xpath>
        </field>
    </record>

    <record id="project_view_kanban_inherit_project_feedback" model="ir.ui.view">
        <field name="name">project.kanban.inherit.project.feedback</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="priority">201</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='card_menu_view']" position="inside">
                <div role="menuitem">
                    <a name="action_view_feedback_project" type="object">Project Feedback</a>
                </div>
            </xpath>
        </field>
    </record>

    <record id="project_sharing_project_task_view_tree_custom" model="ir.ui.view">
        <field name="name">project.sharing.project.task.list</field>
        <field name="model">project.task</field>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <list string="Tasks" sample="1" delete="0" import="0">
                <field name="is_closed" column_invisible="1"/>
                <field name="sequence" column_invisible="1" readonly="1"/>
                <field name="allow_milestones" column_invisible="1"/>
                <field name="allow_timesheets" column_invisible="1"/>
                <field name="allow_task_dependencies" column_invisible="1"/>
                <field name="priority" widget="priority" optional="show" nolabel="1"/>
                <field name="id" optional="show"/>
                <field name="name" widget="name_with_subtask_count"/>
                <field name="company_id" column_invisible="1"/>
                <field name="milestone_id" column_invisible="not allow_milestones"/>
                <field name="planned_date_begin"/>
                <field name="date_deadline"/>
                <field name="partner_id" optional="hide"/>
                <field name="portal_user_names" string="Assignees" optional="show"/>
                <field name="allocated_hours" widget="timesheet_uom_no_toggle" sum="Initially Planned Hours" optional="hide" column_invisible="not allow_timesheets"/>
                <field name="estimate_time" widget="timesheet_uom_no_toggle" sum="Requirement Estimated Time" optional="hide"/>
                <field name="subtask_effective_hours" widget="timesheet_uom" column_invisible="not allow_timesheets" optional="hide"/>
<!--                column_invisible="not allow_task_dependencies or not allow_timesheets"-->
                <field name="effective_hours" widget="timesheet_uom"  sum="Effective Hours" optional="hide" column_invisible="not allow_timesheets"/>
                <field name="total_hours_spent" widget="timesheet_uom"
                       column_invisible="not allow_timesheets" optional="hide"/>
<!--                column_invisible="not allow_task_dependencies or not allow_timesheets"-->
                <field name="remaining_hours" widget="timesheet_uom"  sum="Remaining Hours" optional="hide"
                       decoration-danger="progress &gt;= 100"
                       decoration-warning="progress &gt;= 80 and progress &lt; 100"
                       column_invisible="not allow_timesheets"/>
                <field name="remaining_hours_so"  optional="hide" widget="timesheet_uom"/>
                <field name="progress" widget="progressbar"
                       column_invisible="not allow_timesheets" optional="hide"/>
                <field name="date_deadline" optional="hide" widget="remaining_days"
                       invisible="is_closed"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" optional="show"/>
                <field name="state" widget="project_task_state_selection" nolabel="1" optional="show"/>
                <field name="stage_id" invisible="context.get('set_visible',False)" optional="show"/>
            </list>
        </field>
    </record>

    <record id="project.project_sharing_tree_action_view" model="ir.actions.act_window.view">
        <field name="view_mode">list</field>
        <field name="act_window_id" ref="project.project_sharing_project_task_action"/>
        <field name="view_id" ref="cap_project_feedback.project_sharing_project_task_view_tree_custom"/>
    </record>

</odoo>
