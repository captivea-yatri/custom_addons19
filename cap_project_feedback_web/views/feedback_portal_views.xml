<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="project_feedback_view_tree_portal" model="ir.ui.view">
        <field name="name">project.feedback.view.tree.portal</field>
        <field name="model">project.feedback</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description" widget="html" type="html"/>
                <field name="project_id"/>
                <field name="assignee_id"/>
                <field name="phase_id" />
                <field name="priority" widget="priority"/>
                <field name="estimated_effort"/>
                <field name="estimated_hours" widget="float_time"/>
                <field name="impact_on_timeline"/>
                <field name="maturity"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="feedback_portal_view_form_portal" model="ir.ui.view">
        <field name="name">feedback.portal.form.view</field>
        <field name="model">project.feedback</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" string="Status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="default_domain_ids" invisible="1"/>
                            <field name="name" string="Feedback Summary"/>
                            <field name="project_id" readonly="1" options="{'no_open': 1}" force_save="True"/>
                            <field name="assignee_id" readonly="1" options="{'no_open': 1}"/>
                            <field name="default_domain_id" readonly="1"
                                   options="{'no_create': True,'no_open': True, 'no_create_edit':True}"/>
                            <field name="phase_id" readonly="1"
                                   options="{'no_create': True, 'no_create_edit':True, 'no_open': 1}"/>
                            <field name="estimated_effort" readonly="1"/>
                            <field name="maturity" readonly="1"/>
                        </group>
                        <group>
                            <field name="priority" widget="priority" readonly="1"/>
                            <field name="estimated_hours" widget="float_time" readonly="1"/>
                            <field name="impact_on_timeline" readonly="1"/>
                            <field name="transformed_in_task" readonly="True"/>
                            <field name="tag_ids" widget="many2many_tags" readonly="1"/>
                            <field name="task_id" options="{'no_create': True, 'no_create_edit':True, 'no_open': 1}"
                                   readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="description_page" string="Description">
                            <field name="description" widget="html" type="html" placeholder="description..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_project_feedback_portal" model="ir.actions.act_window">
        <field name="name">Feedback</field>
        <field name="res_model">project.feedback</field>
        <field name="view_mode">list,form</field>
        <field name="context">{
            'tree_view_ref': 'cap_project_feedback_web.project_feedback_view_tree_portal',
            'form_view_ref': 'cap_project_feedback_web.feedback_portal_view_form_portal'}
        </field>
        <field name="view_ids"
                   eval="[(5, 0, 0),
                          (0, 0, {'view_mode': 'list', 'view_id': ref('cap_project_feedback_web.project_feedback_view_tree_portal')}),
                          (0, 0, {'view_mode': 'form', 'view_id': ref('cap_project_feedback_web.feedback_portal_view_form_portal')})]"/>
    </record>


    <record id="cap_project_task_view_feedback_portal_view_form" model="ir.ui.view">
        <field name="name">project.task.view.form</field>
        <field name="model">project.task</field>
        <field name="inherit_id"
               ref="cap_project_feedback.cap_project_feedback_inherited_project_sharing_project_task_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='status']" position="after">
                <button name="action_read_portal_feedback" type="object" string="Setup"
                        class="float-end btn-secondary"/>
            </xpath>
        </field>
    </record>
</odoo>
