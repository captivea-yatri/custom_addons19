<odoo>
    <!-- List View -->
    <record id="view_milestone_purchase_order_list" model="ir.ui.view">
        <field name="name">milestone.purchase.order.list</field>
        <field name="model">milestone.purchase.order</field>
        <field name="arch" type="xml">
            <list string="Purchase Orders" editable="bottom" create="true" edit="true">
                <field name="po_number"/>
                <field name="po_date"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="quantity" optional="hide"/>
                <field name="basic_rate"/>
                <field name="amount"/>
                <field name="balance_quantity"/>
            </list>
        </field>
    </record>



    <!-- Action -->
    <record id="action_milestone_purchase_order" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="res_model">milestone.purchase.order</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Menu -->
    <menuitem id="milestonelegacydata" name="Milestone Legacy Data" action="action_milestone_purchase_order" web_icon="ocgt_milestone_legacy_data,static/description/icon.png"/>
    <menuitem id="Milestone_child" name="Purchase" parent="milestonelegacydata" action="action_milestone_purchase_order"/>

</odoo>
