<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_compensate" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.compensater</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='default_accounts']" position="after">
                <div class="row mt16 o_settings_container" id="ksc_auto_compensate_settings">
                    <div class="o_setting_right_pane">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <span class="o_form_label">The following default accounts are used for auto compensation.
                            </span>
                            <div class="row mt8">
                                <label for="compensate_journal_id" class="col-lg-5 o_light_label"/>
                                <field name="compensate_journal_id"/>
                            </div>
                            <div class="row mt8">
                                <label for="compensate_account_payable_id" class="col-lg-5 o_light_label"/>
                                <field name="compensate_account_payable_id"/>
                            </div>
                            <div class="row mt8">
                                <label for="compensate_account_receivable_id" class="col-lg-5 o_light_label"/>
                                <field name="compensate_account_receivable_id"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
