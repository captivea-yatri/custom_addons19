<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ksc_auto_compensate_view" model="ir.ui.view">
            <field name="name">ksc.auto.compensate.view</field>
            <field name="model">ksc.auto.compensate</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="amount" readonly="0" invisible="1"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="invoice_bill_ids">
                                 <list create="false" delete="false" editable="bottom">
                                     <field name="is_select" readonly="0"/>
                                     <field name="inv_bill_number" readonly="1"/>
                                     <field name="currency_id" column_invisible="True"/>
                                     <field name="inv_bill_id" column_invisible="True"/>
                                     <field name="inv_bill_amount" readonly="1"/>
                                     <field name="is_partial_paid" readonly="1"/>
                                     <field name="compensate_id" column_invisible="True"/>
                                 </list>
                             </field>
                        </group>
                    </sheet>
                    <footer>
                        <button string="Reconcile" name="do_reconcile" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
