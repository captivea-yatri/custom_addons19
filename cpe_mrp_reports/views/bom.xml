<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="bom_extended" model="ir.ui.view">
        <field name="name">bom.extended</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="before">
                <header>
                    <button name="%(mrp_report_cost_review_window_action)d"
                            type="action"
                            string="BOM Cost Review"
                            class="btn btn-primary"/>
                </header>
            </xpath>
        </field>
    </record>

</odoo>
