<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="deferred_revenue_product_form_new" model="ir.ui.view">
        <field name="name">deferred.revenue.product.form.new</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="sale_planning.product_template_form_view_invoice_policy_inherit_sale_planning"/>
        <field name="arch" type="xml">
            <div name="service_policy_div" position="after">
                <field name="x_studio_product_to_receive"/>
                <field name="emp_filter_domain" widget="domain" options="{'model': 'hr.employee', 'in_dialog': true}"/>
                <field name="restrict_description_modification"/>
            </div>
        </field>
    </record>

    <record id="deferred_revenue_product_form" model="ir.ui.view">
        <field name="name">deferred.revenue.product.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="priority">17</field>
        <field name="arch" type="xml">
            <xpath expr="//label[@for='standard_price']" position="before">
                <field name="minimumSalePrice"
                       groups="ksc_sale_project_extended.group_allow_product_minimum_sale_price"/>
            </xpath>
            <xpath expr="//div[@name='options']" position="inside">
                <div>
                    <field name="skip_for_sale_ok"/>
                    <label for="skip_for_sale_ok"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
