<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_project_project_inherit_form" model="ir.ui.view">
        <field name="name">project.project.view.inherit</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="sale_timesheet.project_project_view_form"/>
        <field name="arch" type="xml">
            <field name="sale_line_employee_ids" position="before">
                <group>
                    <field name="accessible_so_line_ids" widget="many2many_tags" invisible="1"/>
                    <field name="sale_order_ids" widget="many2many_tags" string='Sale Orders'/>
                    <field name="sale_order_line_ids" context="{'with_remaining_hours': True}" widget="many2many_tags" domain="[('id', 'in', accessible_so_line_ids)]"/>
                </group>
                <br/>
                <hr/>
            </field>
        </field>
    </record>


    <record id="view_project_project_sale_item_inherit_form" model="ir.ui.view">
        <field name="name">project.project.view.inherit</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sale_line_id' and @groups='!sales_team.group_sale_salesman']"
                   position="attributes">
                <attribute name="context">{'with_remaining_hours': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='sale_line_id' and @groups='sales_team.group_sale_salesman']"
                   position="attributes">
                <attribute name="context">{'with_remaining_hours': True, 'form_view_ref':
                    'sale_project.sale_order_line_view_form_editable', 'default_partner_id': partner_id,
                    'default_company_id': company_id}
                </attribute>
            </xpath>
        </field>
    </record>

    <record id="project_task_view_form_inherit_sale_timesheet" model="ir.ui.view">
        <field name="name">project.task.form.view.form.inherit.sale.timesheet</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="sale_timesheet.project_task_view_form_inherit_sale_timesheet"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='timesheet_ids']/list/field[@name='so_line']" position="after">
                <field name="commercial_partner_id"/>
            </xpath>
            <xpath expr="//field[@name='timesheet_ids']/list/field[@name='so_line']" position="attributes">
               <attribute name="domain">[('is_service', '=', True), ('order_partner_id', 'child_of', commercial_partner_id), ('is_expense', '=', False), ('state', 'in', ['sale', 'done']), ('project_id', '=', project_id)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>
