<odoo>
    <record id="view_sale_order_form_inherit_lead" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.lead</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="new_lead_id"/>
            </xpath>
        </field>
    </record>
</odoo>
