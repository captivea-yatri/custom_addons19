<odoo>
    <record id="view_sale_order_list_ksc" model="ir.ui.view">
        <field name="name">sale.order.ksc.list</field>
        <field name="model">sale.order.ksc</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="date_order"/>
                <field name="state"/>
                <field name="lead_id"/>
            </list>
        </field>
    </record>

    <record id="view_sale_order_form_ksc" model="ir.ui.view">
        <field name="name">sale.order.ksc.form</field>
        <field name="model">sale.order.ksc</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="customer_id"/>
                        <field name="invoice_customer_id"/>
                        <field name="shipping_customer_id"/>
                        <field name="date_order"/>
                        <field name="state"/>
                        <field name="lead_id"/>
                    </group>


                </sheet>
            </form>
        </field>
    </record>
        <record id="view_sale_order_form_ksc" model="ir.ui.view">
    <field name="name">sale.order.ksc.form</field>
    <field name="model">sale.order.ksc</field>
    <field name="arch" type="xml">
        <form string="Sales Quotation">
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="customer_id"/>
                    <field name="date_order"/>
                    <field name="order_total" readonly="1"/>
                </group>

                <field name="order_line_ids">
                    <list editable="bottom">
                        <field name="name"/>
                        <field name="uom_id"/>
                        <field name="quantity"/>
                        <field name="unit_price"/>
                        <field name="subtotal_without_tax" readonly="1"/>
                    </list>
                </field>
            </sheet>
        </form>
    </field>
</record>





    <record id="action_sale_order_ksc" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">sale.order.ksc</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_sale_order_ksc"
              parent="menu_my_sales_sales"
              name="Orders"
              action="action_sale_order_ksc"/>
</odoo>
