<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_warehouse_list_ksc" model="ir.ui.view">
        <field name="name">crm.warehouse.ksc.list</field>
        <field name="model">stock.warehouse.ksc</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="short_code"/>
                <field name="address"/>

                <field name="view_location_id"/>
            </list>
        </field>
    </record>

    <record id="view_warehouse_form_ksc" model="ir.ui.view">
        <field name="name">crm.warehouse.ksc.form</field>
        <field name="model">stock.warehouse.ksc</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name"/>
                    <field name="short_code"/>
                    <field name="address"/>

                    <field name="view_location_id"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_stock_warehouse" model="ir.actions.act_window">
        <field name="name">Ware House </field>
        <field name="res_model">stock.warehouse.ksc</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_stock_warehouse"
              name="WareHouse"
              parent="menu_my_sales_category"
              action="action_stock_warehouse"/>
</odoo>
