<odoo>
    <record id="view_product_ksc_list" model="ir.ui.view">
        <field name="name">product.ksc.list</field>
        <field name="model">product.ksc</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="sku"/>
                <field name="barcode"/>
                <field name="sale_price"/>
                <field name="category_id"/>
            </list>
        </field>
    </record>

    <record id="view_product_ksc_form" model="ir.ui.view">
        <field name="name">product.ksc.form</field>
        <field name="model">product.ksc</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sku"/>
                        <field name="barcode"/>
                        <field name="product_type"/>
                        <field name="category_id"/>
                        <field name="uom_id"/>
                    </group>

                    <group string="Dimensions">
                        <field name="weight"/>
                        <field name="length"/>
                        <field name="width"/>
                        <field name="volume"/>
                    </group>

                    <group string="Price">
                        <field name="sale_price"/>
                        <field name="cost_price"/>
                        <field name="list_price"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_product_ksc_search" model="ir.ui.view">
        <field name="name">product.ksc.search</field>
        <field name="model">product.ksc</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="sku"/>
                <field name="barcode"/>
            </search>
        </field>
    </record>

    <record id="action_product_ksc" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.ksc</field>
        <field name="view_mode">list,form,search</field>
        <field name="search_view_id" ref="view_product_ksc_search"/>
    </record>

    <menuitem id="menu_product_ksc"
              name="Products"
              parent="menu_my_sales_sales"
              action="action_product_ksc"/>
</odoo>
