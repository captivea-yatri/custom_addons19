<odoo>
    <!-- List View -->
    <record id="view_res_partner_list_ksc" model="ir.ui.view">
        <field name="name">res.partner.ksc.list</field>
        <field name="model">res.partner.ksc</field>
        <field name="arch" type="xml">
            <list string="Customers">
                <field name="name"/>
                <field name="country_id"/>
                <field name="state_id"/>
                <field name="email"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_res_partner_form_ksc" model="ir.ui.view">
        <field name="name">res.partner.ksc.form</field>
        <field name="model">res.partner.ksc</field>
        <field name="arch" type="xml">
            <form string="Customer">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="street1"/>
                        <field name="street2"/>
                        <field name="country_id"/>
                        <field name="state_id"/>
                        <field name="city_id"/>
                        <field name="zip"/>
                    </group>

                    <group string="Contact Info">
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="mobile"/>
                        <field name="website"/>
                    </group>

                    <group>
                        <field name="photo"/>
                        <field name="active"/>
                    </group>

                    <notebook>
                        <page string="Child Addresses">
                            <field name="child_ids" context="{'default_parent_id': id}">
                                <!-- ✅ Fixed Kanban View (no owl directives) -->
                                <kanban>
                                    <templates>
                                        <t t-name="card">
                                            <div class="oe_kanban_global_click o_kanban_card">
                                                <div>
                                                    <field name="photo" widget="image" class="oe_avatar" options="{'preview_image': 'photo'}"/>
                                                </div>
                                                <div>
                                                    <strong><field name="name"/></strong><br/>
                                                    <field name="address_type"/>
                                                    <field name="city_id"/>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>

                                <!-- Form View for One2many -->
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="address_type"/>
                                        <field name="street1"/>
                                        <field name="street2"/>
                                        <field name="country_id"/>
                                        <field name="state_id"/>
                                        <field name="city_id"/>
                                        <field name="zip"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_res_partner_ksc" model="ir.actions.act_window">
        <field name="name">Customer</field>
        <field name="res_model">res.partner.ksc</field>
        <field name="domain">[('parent_id','=',False)]</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_customer_ksc"
              parent="menu_my_sales_sales"
              name="Customer"
              action="action_res_partner_ksc"/>
</odoo>
