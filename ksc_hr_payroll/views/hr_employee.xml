<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payroll_hr_employee_view_form_inherit" model="ir.ui.view">
        <field name="name">payroll.hr.employee.view.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']/group[@name='settings_group']" position="inside">
                <field name="partner_id"/>
            </xpath>
            <xpath expr="//page[@name='hr_settings']/group[@name='settings_group']" position="inside">
                <field name="medical_visit_date"/>
            </xpath>
        </field>
    </record>
</odoo>
