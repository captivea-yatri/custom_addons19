<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="library_list_view" model="ir.ui.view">
        <field name="name">library.list.view</field>
        <field name="model">library</field>
        <field name="arch" type="xml">
            <list>
                <field name="book_name"/>
                <field name="author_name"/>
                <field name="edition"/>
                <field name="chk_in"/>
                <field name="chk_out"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="library_form_view" model="ir.ui.view">
        <field name="name">library.form.view</field>
        <field name="model">library</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="book_name"/>
                <field name="author_name"/>
                <field name="edition"/>
                <field name="chk_in"/>
                <field name="chk_out"/>
                </group>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="library_action" model="ir.actions.act_window">
        <field name="name">library</field>
        <field name="res_model">library</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENUS -->
    <!-- <menuitem id="Teacher" name="Teacher1"/> -->
    <menuitem id="library_child" name="Library" parent="School_management" action="library_action"/>
</odoo>