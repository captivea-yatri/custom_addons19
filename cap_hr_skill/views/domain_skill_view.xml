<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="domain_skill_tree_view" model="ir.ui.view">
            <field name="name">domain.skill.tree.view</field>
            <field name="model">hr.domain.skill</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="skill_type_id"/>
                </list>
            </field>
        </record>

        <record id="domain_skill_form_view" model="ir.ui.view">
            <field name="name">domain.skill.form.view</field>
            <field name="model">hr.domain.skill</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="skill_type_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

         <record id="domain_skill_search_view" model="ir.ui.view">
            <field name="name">domain.skill.search.view</field>
                <field name="model">hr.domain.skill</field>
                <field name="arch" type="xml">
                     <search string="Domain Skills">
    <field name="name"/>
    <filter string="Has Skill Type"
            name="filter_has_skill_type"
            domain="[('skill_type_id', '!=', False)]"
            context="{'default_skill_type_id': False}"/>

        <filter string="Name" name="group_by_name" context="{'group_by':'name'}"/>
        <filter string="Skill Type" name="group_by_skill_type_id" context="{'group_by':'skill_type_id'}"/>

</search>

            </field>
         </record>

        <record id="action_domain_skill" model="ir.actions.act_window">
            <field name="name">Skills Domain</field>
            <field name="res_model">hr.domain.skill</field>
            <field name="view_mode">list,form</field>
        </record>
        
        <menuitem id="domain_skill_main_menu" action="action_domain_skill"
                  name="Skills Domain" parent="hr.menu_config_employee"/>
    </data>
</odoo>
