<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_hr_skill" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.hr_skill</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="70"/>
        <field name="inherit_id" ref="hr.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app/block[@name='employees_setting_container']" position="inside">
                <h2>Limitation Of Skill Request</h2>
                <div class="row mt16 o_settings_container">
                    <div class="o_setting_right_pane">
                        <div class="col-12 col-lg-6 o_setting_box" title="Limitation Of Skill Request">
                            <span class="o_form_label">Limitation Of Skill Request</span>
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="limitation_of_skill_request"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>