<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="city_list_view" model="ir.ui.view">
        <field name="name">city.list.view</field>
        <field name="model">city</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="sh_name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="city_form_view" model="ir.ui.view">
        <field name="name">city.form.view</field>
        <field name="model">city</field>
        <field name="arch" type="xml">
            <form>
                <group>
                <field name="name"/>
                <field name="sh_name"/>
                <field name="active"/>
                </group>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="city_action" model="ir.actions.act_window">
        <field name="name">city</field>
        <field name="res_model">city</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENUS -->
    <menuitem id="Localization" name="Cities"/>
    <menuitem id="city_child" name="Cities" parent="Localization" action="city_action"/>



</odoo>
