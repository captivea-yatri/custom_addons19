    <!--    Task Views-->
    <record id="project_task_view_form_inherit_custom" model="ir.ui.view">
        <field name="name">project.task.view.form.inherit.custom</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="timesheet_grid.project_task_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_timer_start']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header/button[@name='action_timer_start'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="project_view_task_kanban_ksc" model="ir.ui.view">
        <field name="name">project.view.task.kanban.ksc</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <field name="subtask_count" position="after">
                <field name="color_state"/>
                <field name="warning_msg"/>
            </field>
            <xpath expr="//main/field[@name='tag_ids']" position="after">
                <br/>
                <t t-if="record.color_state.value == 'red'">
                    <p t-esc="record.warning_msg.value" style="color:red;"/>
                </t>
                <t t-if="record.color_state.value == 'orange'">
                    <p t-esc="record.warning_msg.value" style="color:orange;"/>
                </t>
            </xpath>
        </field>
    </record>

