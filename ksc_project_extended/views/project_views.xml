<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--    Project Views-->
    <record id="project_project_view_tree_inherited_ksc" model="ir.ui.view">
        <field name="name">project.project.view.tree.inherited.ksc</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project"/>
        <field name="priority">16</field>
        <field name="arch" type="xml">
            <xpath expr="/list/field[@name='sequence']" position="after">
                <field name="color" invisible="1"/>
                <button icon="fa-circle text-success"
                        title=" "
                        invisible="color != 10"/>
                <button icon="fa-circle text-danger"
                        title=" "
                        invisible="color != 1"/>
                <button icon="fa-circle text-warning"
                        title=" "
                        invisible="color != 2"/>
            </xpath>
        </field>
    </record>

    <record id="edit_project_task_inherit" model="ir.ui.view">
        <field name="name">project.project.form.task.inherit</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/field[@name='company_id']" position="after">
                <field name="partner_salesperson"/>
                <!--pending-->
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" name="action_project_timesheets" type="object"
                        icon="fa-calendar"
                        invisible="not allow_timesheets"
                        groups="hr_timesheet.group_hr_timesheet_user">
                    <div class="o_field_widget o_stat_info">
                        <div class="oe_inline">
                            <span class="o_stat_value mr-1">
                                <field name="total_timesheet_time" widget="statinfo" nolabel="1"
                                       groups="hr_timesheet.group_hr_timesheet_user"/>
                            </span>
                            <span class="o_stat_value">
                                <field name="timesheet_encode_uom_id" class="o_stat_text" options="{'no_open' : True}"/>
                            </span>
                        </div>
                        <span class="o_stat_text">Recorded</span>
                    </div>
                </button>
            </xpath>

            <xpath expr="//div[@name='button_box']/button[@name='action_view_tasks']" position="replace">
                <button class="oe_stat_button" type="object" name="action_view_tasks_from_project" icon="fa-check">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Tasks</span>
                        <span class="o_stat_value">
                            <field name="closed_task_count"/>
                            /
                            <field name="task_count"/>
                            (<field name="task_completion_percentage" widget="percentage" options="{'digits': [1, 0]}"/>
                            )
                        </span>
                    </div>
                </button>
            </xpath>


            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="x_studio_remaining_hours"/>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="before">
                <field name="on_hold_reason" widget="selection" readonly="0" force_save="true"
                       options="{'no_create_edit': True}"/>
            </xpath>
            <xpath expr="//button[@name='project_update_all_action']" position="replace"/>
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="business_analyst_ids" widget="many2many_tags"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
                <field name="developers_ids" widget="many2many_tags"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
                <field name="configurators_ids" widget="many2many_tags"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
                <field name="architect_ids" widget="many2many_tags"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
            </xpath>
            <xpath expr="//group[@name='group_sales_invoicing']" position="after">
                <group groups="!ksc_project_extended.group_project_pmm_report" name="group_sprint_meeting"
                       string="PMM REPORT CONFIGURATION" col="1"
                       class="row mt16 o_settings_container">
                    <div class="o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="no_pm_report" readonly="1"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="no_pm_report"/>
                        </div>
                    </div>
                    <div class="o_setting_box" name="report_frequency_in_days_readonly">
                        <div class="o_setting_left_pane">
                            <field name="report_frequency_in_days" readonly="1"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <div>
                                Report Frequency Days
                            </div>
                        </div>
                    </div>
                </group>
                <group name="group_sprint_meeting" groups="ksc_project_extended.group_project_pmm_report"
                       string="PMM REPORT CONFIGURATION" col="1"
                       class="row mt16 o_settings_container">
                    <div class="o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="no_pm_report"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="no_pm_report"/>
                        </div>
                    </div>
                    <div class="o_setting_box" name="report_frequency_in_days_editable">
                        <div class="o_setting_left_pane">
                            <field name="report_frequency_in_days"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <div>
                                Report Frequency Days
                            </div>
                        </div>
                    </div>
                </group>
                <group name="group_exclude_for_quality_issue_production_review"
                       groups="ksc_project_extended.group_project_pmm_report"
                       string="MANAGE QUALITY ISSUE &amp; PRODUCTION REVIEW" col="1"
                       class="row mt16 o_settings_container">
                    <div class="o_setting_box" name="setting_production_review">
                        <div class="o_setting_left_pane">
                            <field name="exclude_for_production_review"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="exclude_for_production_review"/>
                        </div>
                    </div>
                    <div class="o_setting_box" name="setting_quality_go_live">
                        <div class="o_setting_left_pane">
                            <field name="exclude_for_go_live"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="exclude_for_go_live"/>
                        </div>
                    </div>
                    <div class="o_setting_box" name="setting_quality_test">
                        <div class="o_setting_left_pane">
                            <field name="exclude_for_tests"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="exclude_for_tests"/>
                        </div>
                    </div>
                    <div class="o_setting_box" name="setting_quality_feedback">
                        <div class="o_setting_left_pane">
                            <field name="exclude_for_feedback"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="exclude_for_feedback"/>
                        </div>
                    </div>
                </group>
                <group name="group_exclude_for_quality_issue_production_review"
                       groups="!ksc_project_extended.group_project_pmm_report"
                       string="MANAGE QUALITY ISSUE &amp; PRODUCTION REVIEW" col="1"
                       class="row mt16 o_settings_container">
                    <div class="o_setting_box" name="setting_production_review_readonly">
                        <div class="o_setting_left_pane">
                            <field name="exclude_for_production_review" readonly="1"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="exclude_for_production_review"/>
                        </div>
                    </div>
                    <div class="o_setting_box" name="setting_quality_go_live_readonly">
                        <div class="o_setting_left_pane">
                            <field name="exclude_for_go_live" readonly="1"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="exclude_for_go_live"/>
                        </div>
                    </div>
                    <div class="o_setting_box" name="setting_quality_test_readonly">
                        <div class="o_setting_left_pane">
                            <field name="exclude_for_tests" readonly="1"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="exclude_for_tests"/>
                        </div>
                    </div>
                    <div class="o_setting_box" name="setting_quality_feedback_readonly">
                        <div class="o_setting_left_pane">
                            <field name="exclude_for_feedback" readonly="1"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="exclude_for_feedback"/>
                        </div>
                    </div>
                </group>
            </xpath>
            <xpath expr="//sheet/notebook" position="inside">
                <page name="sprint_meeting_docs" string="Old Sprint Meeting Doc">
                    <field name="attachment_ids" readonly="1">
                        <list no_open="1">
                            <field name="name"/>
                            <field name="description"/>
                            <field name="datas" filename="name" widget="binary"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

<!--    TODO: need to check time-remaining widget in kanban view in database-->
    <record id="project_project_view_kanban_inherited_ksc" model="ir.ui.view">
        <field name="name">project.project.view.kanban.inherited.ksc</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="priority">25</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="after">
                <div class="o_kanban_card_manage_settings" style="margin-bottom: -10px;">
                    <span class="o_label ms-1">
                        <strong>
                            <field name="label_studio_remaining_hours"/>
                            :
                        </strong>
                    </span>
                    <span class="o_value">
                        <field name="x_studio_remaining_hours"/>
                    </span>
                </div>
            </xpath>
        </field>
    </record>

    <record id="edit_project_form_inherit_restrict_manual_timesheet" model="ir.ui.view">
        <field name="name">project.project.form.restrict.manual.timesheet</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project_forecast.project_view_form_inherit_project_forecast"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_time_managment']" position="inside">
                <div class="o_setting_box" id="restricted_manual_timesheet">
                    <div class="o_setting_left_pane">
                        <field name="restrict_manual_timesheet"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label string="Restrict Timesheet" for="restrict_manual_timesheet"/>
                        <div class="text-muted" id="restrict_manual_timesheet_setting">
                            Restrict Manual Timesheet
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <!--    Window Actions-->
    <record id="project.act_project_project_2_project_task_all" model="ir.actions.act_window">
        <field name="context">{'default_project_id': active_id, 'check_initial_plan_hours': True}</field>
    </record>

    <record id="project.action_view_task" model="ir.actions.act_window">
        <field name="context">{'search_default_my_tasks': 1, 'check_initial_plan_hours': True}</field>
    </record>

    <record id="project.project_task_action_sub_task" model="ir.actions.act_window">
        <field name="context">{'check_initial_plan_hours': True}</field>
    </record>

    <record id="project.open_task_type_form" model="ir.actions.act_window">
        <field name="context">{'check_initial_plan_hours': True}</field>
    </record>

    <record id="project.open_task_type_form_domain" model="ir.actions.act_window">
        <field name="context">{'check_initial_plan_hours': True}</field>
    </record>

