<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="internal_project_quota_view_tree" model="ir.ui.view">
        <field name="name">internal.project.quota.view.tree</field>
        <field name="model">internal.project.quotas</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="project_id"/>
                <field name="hours_per_month"/>
            </list>
        </field>
    </record>

    <record id="internal_project_quota_view_form" model="ir.ui.view">
        <field name="name">internal.project.quota.view.form</field>
        <field name="model">internal.project.quotas</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" required="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" required="1"/>
                            <field name="project_id" required="1"/>
                        </group>
                        <group>
                            <field name="hours_per_month"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_view_internal_project_quota" model="ir.actions.act_window">
        <field name="name">Internal Project Quota</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">internal.project.quotas</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_internal_project_quota" name="Internal Project Quotas"
              parent="hr.menu_human_resources_configuration"
              action="action_view_internal_project_quota"
              groups="ksc_project_extended.access_internal_project_quota"/>
</odoo>
