<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="group_extra_timesheet" model="res.groups">
            <field name="name">Extra Timesheet</field>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_reduce_past_timesheet" model="res.groups">
            <field name="name">Reduce Past Timesheet</field>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_project_pmm_report" model="res.groups">
            <field name="name">PMM Report Config</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

<!--  #################################### Access internal project quota #########################################   -->

        <record id="access_internal_project_quota" model="res.groups">
            <field name="name">Can Access Internal Project Quotas</field>
        </record>

    </data>
</odoo>
