<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="product_account_restriction_tree_view" model="ir.ui.view">
            <field name="name">product.account.restriction.tree</field>
            <field name="model">product.account.restriction</field>
            <field name="arch" type="xml">
                <list>
                    <field name="partner_id"/>
                    <field name="allowed_product_ids" widget="many2many_tags"/>
                    <field name="allowed_account_ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>

        <record id="product_account_restriction_form_view" model="ir.ui.view">
            <field name="name">product.account.restriction.form</field>
            <field name="model">product.account.restriction</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="partner_id" options="{'no_quick_create': True, 'no_create_edit': True}"
                                       required="1"/>
                                <field name="company_id"/>
                            </group>
                            <group>
                                <field name="allowed_product_ids" widget="many2many_tags"
                                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
                                <field name="allowed_account_ids" widget="many2many_tags"
                                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="product_account_restriction_action" model="ir.actions.act_window">
            <field name="name">Product Account Restriction</field>
            <field name="res_model">product.account.restriction</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem action="product_account_restriction_action"
                  id="product_account_restriction_menu"
                  parent="account.menu_finance"
                  sequence="6"
                  groups="base.group_system,account.group_account_manager"/>
    </data>
</odoo>
