<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="project_progress_report_custom_mail_template" model="mail.template">
        <field name="name">Project Progress Report : Request Signature</field>
        <field name="model_id" ref="cap_project_progress_report.model_project_progress"/>
        <field name="subject">{{ object.sign_request_id.reference }}</field>
        <field name="email_from">{{ (object.env.user.login) }}
        </field>
        <field name="reply_to">{{ object.sign_request_item_id.create_uid.email }}</field>
        <field name="description">Edit this template to customize project progress report mail
        </field>
        <field name="body_html" type="html">
            <header>
                <meta http-equiv="Content-Type" content="text/html charset=UTF-8"/>
            </header>
            <body>
                <div style="display: none; max-height: 0px; overflow: hidden; color:#fff; font-size:0px; line-height:0px">
                    <t>
                        <p>Hello
                            <span></span>
                            <t t-esc="object.sign_request_item_id.partner_id.name"/>,
                        </p>
                    </t>
                    <t t-esc="object.env.user.name"/>
                    (
                    <a t-att-href="object._get_mail_link(object.create_uid.email, subject)"
                       style="color:#428BCA; text-decoration:none;"
                       target="_blank">
                        <t t-esc="object.env.user.login"/>
                    </a>
                    )
                    has requested your signature on the document
                    <span></span>
                    <t t-esc="object.sign_request_id.reference"/>.
                </div>
                <table role="presentation" border="0" cellpadding="0" cellspacing="0"
                       style="padding-top: 16px; background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;">
                    <tr>
                        <td align="center">
                            <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="590"
                                   style="padding: 24px; background-color: white; color: #454748; border-collapse:separate;">
                                <tbody>
                                    <tr>
                                        <td align="center" style="min-width: 590px;">
                                            <table role="presentation" border="0" cellpadding="0" cellspacing="0"
                                                   width="100%"
                                                   style="background-color: white; padding: 0; border-collapse:separate;">
                                                <tr>
                                                    <td valign="middle">
                                                        <span style="font-size: 10px;">Your Signature</span>
                                                        <br/>
                                                        <span style="font-size: 20px; font-weight: bold;">
                                                            <t t-esc="object.sign_request_id.reference"/>
                                                        </span>
                                                    </td>
                                                    <td valign="middle" align="right">
                                                        <img style="padding: 0px; margin: 0px; height: 48px;"
                                                             src="http://localhost:1616/logo.png?company=1"
                                                             alt="Captivea LLC"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td colspan="2" style="text-align:center;">
                                                        <hr width="100%"
                                                            style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin:4px 0px 32px 0px;"/>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="min-width: 590px;">
                                            <table border="0" cellpadding="0"
                                                   style="background-color: white; padding: 0px; border-collapse:separate;">
                                                <tr>
                                                    <td valign="top">
                                                        <p>Hello
                                                            <span>
                                                                <t t-esc="object.sign_request_item_id.partner_id.name"/>
                                                            </span>
                                                            ,
                                                        </p>
                                                        <t t-esc="object.env.user.name"/>
                                                        (
                                                        <a t-att-href="object._get_mail_link(object.create_uid.email, subject)"
                                                           style="color:#428BCA; text-decoration:none;"
                                                           target="_blank">
                                                            <t t-esc="object.env.user.login"/>
                                                        </a>
                                                        )
                                                        has requested your signature on the document
                                                        <span></span>
                                                        <t t-esc="object.sign_request_id.reference"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td valign="top">
                                                        <div style="margin: 16px 0px 16px 0px; padding: 8px 16px 8px 16px; background-color: #F1F1F1;">
                                                            <span>
                                                                <p>Sign to validate the Project Progress Report :
                                                                    <span t-esc="object.name"/>
                                                                </p>
                                                            </span>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td valign="top">
                                                        <div style="margin:16px auto; text-align:center;">
                                                            <a t-att-href="object.link"
                                                               style="padding: 8px 16px 8px 16px; border-radius: 3px; background-color:#875A7B; text-align:center; text-decoration:none; color: #FFFFFF;">
                                                                Sign document
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td valign="top">
                                                        <div style="opacity: 0.7;">
                                                            <strong>Warning</strong>
                                                            do not forward this email to other people!
                                                            <br/>
                                                            They will be able to access this document and sign it as
                                                            yourself.
                                                            <br/>
                                                            <span>Your IP address and localization are associated to
                                                                your
                                                                signature to ensure traceability.
                                                            </span>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </table>
                                            <span>--<br/>System
                                            </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td align="center"
                                            style="min-width: 590px; padding: 0 8px 0 8px; font-size:11px;">
                                            <hr width="100%"
                                                style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 4px 0px;"/>
                                            <b>Captivea LLC</b>
                                            <br/>
                                            <div style="color: #999999;">
                                                +1 407-993-6074
                                                |
                                                <a style="text-decoration:none; color: #999999;"
                                                   href="mailto:administrative@captivea.com">
                                                    administrative@captivea.com
                                                </a>
                                                |
                                                <a style="text-decoration:none; color: #999999;"
                                                   href="https://www.captivea.com">https://www.captivea.com
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td align="center" style="min-width: 590px;">
                            Powered by
                            <a target="_blank" href="https://www.odoo.com?utm_source=db&amp;utm_medium=email"
                               style="color: #875A7B;">Odoo
                            </a>
                        </td>
                    </tr>
                </table>
            </body>
        </field>
        <field name="lang">{{ object.sudo().project_id.partner_id.lang }}</field>
        <field name="auto_delete" eval="False"/>
    </record>
</odoo>
