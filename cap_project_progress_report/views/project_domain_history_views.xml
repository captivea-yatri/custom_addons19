<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="project_domain_history_list_inherit" model="ir.ui.view">
        <field name="name">project.domain.history.inherit.view.tree</field>
        <field name="model">project.domain.history</field>
        <field name="inherit_id" ref="cap_requirements.project_domain_history_tree_view"/>
        <field name="priority" eval="999"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='task_passed_time']" position="after">
                <field name="task_progress"/>
            </xpath>
        </field>
    </record>
    <record id="project_domain_history_form_inherit" model="ir.ui.view">
        <field name="name">project.domain.history.inherit.view.form</field>
        <field name="model">project.domain.history</field>
        <field name="inherit_id" ref="cap_requirements.project_domain_history_form_view"/>
        <field name="priority" eval="999"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='task_passed_time']" position="after">
                <field name="task_progress" invisible="1"/>
            </xpath>
        </field>
    </record>

</odoo>
