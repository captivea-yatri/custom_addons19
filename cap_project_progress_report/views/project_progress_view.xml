<odoo>
    <data>
        <record id="project_progress_view_form" model="ir.ui.view">
            <field name="name">project.progress.view.form</field>
            <field name="model">project.progress</field>
            <field name="arch" type="xml">
                <form create="0">
                    <header>
                        <button name="action_project_progress_send" string="Send the Project progress Report" type="object" data-hotkey="q"
                                invisible="status != 'draft'"/>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <div class="oe_title">
                            <h3>
                                <field name="project_id" options="{'no_create': True, 'no_create_edit': True}"
                                       readonly="status != 'draft'"/>
                                <field name="company_id" invisible="1"/>
                            </h3>
                        </div>
                        <group>
                            <group>
                            <field name="phase_id" options="{'no_create': True, 'no_create_edit': True}"
                                       required="1"/>
                            <field name="project_status_id"/>
                            <field name="go_live_date"/>
                            <field name="project_progress_template"/>
                            <field name="signatory_portal_report_partner_ids" invisible="1"/>
                            <field name="cc_progress_report_internal_partner_partner_ids" invisible="1"/>
                            <field name="signatory_progress_report_partner_id" options="{'no_create': True, 'no_create_edit': True}" domain="[('id', 'in', signatory_portal_report_partner_ids)]"/>
                            <field name="cc_progress_report_partner_ids"
                                   options="{'no_create': True, 'no_create_edit': True}" widget="many2many_tags" domain="[('id', 'in', cc_progress_report_internal_partner_partner_ids)]"/>
                            </group>
                            <group>
                                <field name="global_progress" readonly="1" force_save="1" widget="percentage"/>
                                <field name="validation_progress" readonly="1" force_save="1" widget="percentage"/>
                                <field name="out_of_scope_included_in_current_phase" readonly="1" force_save="1"/>
                                <field name="last_report" invisible="1"/>
                                <field name="remaining_hours"/>
                                <field name="left_hours" readonly="1" force_save="1"/>
                                <field name="create_date"/>
                                <button name="calculate_the_progress_remaining_hours" string="Calculate" type="object"
                                        invisible="status != 'draft'"
                                        class="oe_highlight" help="Creates project domain history also calculate global progress, validation progress, out of scope tasks and remaining hours"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="project_domain_history" string="Project Domain History">
                                <field name="project_domain_history_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="status"/>
                                        <field name="estimated_time" sum="Total Estimated Time"/>
                                        <field name="task_estimated_time" sum="Total Task Estimated Time"/>
                                        <field name="task_passed_time" sum="Total Passed Time"/>
                                        <field name="task_progress"/>
                                    </list>
                                </field>
                            </page>
                            <page name="past_done_task_history" string="Past Done Tasks History">
                                <field name="past_done_task_history_ids" domain="[('project_id', '=', project_id)]"
                                       context="{'default_project_id': project_id}">
                                    <list>
                                        <field name="sequence" widget="handle"/>
                                        <field name="related_task_id"/>
                                        <field name="task_id"/>
                                        <field name="is_planned"/>
                                        <field name="domain" />
                                        <field name="state" readonly="1" force_save="1"/>
                                    </list>
                                </field>
                            </page>
                            <page name="task_on_hold" string="Tasks on Hold">
                                <field name="hold_task_ids"
                                       domain="['|',('default_phase_id','=',phase_id),('default_phase_id','=',False),('project_id', '=', project_id)]"
                                       context="{'default_project_id': project_id}">
                                    <list>
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="user_ids" widget="many2many_avatar_user"/>
                                        <field name="allocated_hours"/>
                                        <field name="remaining_hours"/>
                                        <field name="tag_ids" widget="many2many_tags"/>
                                        <field name="planned_date_begin"/>
                                        <field name="planned_date_start"/>
                                        <field name="default_domain_ids" column_invisible="True"/>
                                        <field name="default_domain_id" readonly="1" string="Domain"/>
                                        <field name="stage_id"/>
                                    </list>
                                </field>
                            </page>
                            <page name="next_planned_task" string="Tasks Planned for Next Week">
                                <field name="future_task_ids"
                                       domain="['|',('default_phase_id','=',phase_id),('default_phase_id','=',False),('project_id', '=', project_id)]"
                                       context="{'default_project_id': project_id}">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="select"/>
                                        <field name="id"/>
                                        <field name="name"/>
                                        <field name="default_domain_ids" column_invisible="True"/>
                                        <field name="default_domain_id" readonly="1" string="Domain"/>
                                        <field name="planned_date_begin"/>
                                        <field name="allocated_hours"/>
                                        <field name="remaining_hours"/>
                                    </list>
                                </field>
                                <span>Remove the Tasks and Add <field name="days" widget="number" style="width: 50px;"/> Days to the start date. </span>
                                <button name="change_planned_date" string="Validate" class="btn-primary" type="object"/>
                            </page>
                            <page name="meetings_to_come" string="Meetings To Come">
                                <group>
                                    <field name="demo_meeting_task"/>
                                    <!--                                    <field name="pmm_meeting"/>-->
                                </group>
                            </page>
                            <page name="time_tracking" string="Time Tracking">
                                <field name="sale_order_line_ids" readonly="1" force_save="1">
                                    <list>
                                        <field name="order_id"/>
                                        <field name="product_uom_qty"/>
                                        <field name="x_studio_consumed_qty"/>
                                        <field name="x_studio_remaining_quantity"/>
                                    </list>
                                </field>
                                <hr/>
                                <br/>
                                <strong>Consumption of your credit time of last 4 weeks</strong>
                                <hr/>
                                <field name="weekly_hour_consumption_ids" readonly="1" force_save="1">
                                    <list create="false" edit="false" delete="false" no_open="1">
                                        <field name="week_tminusthree"/>
                                        <field name="week_tminustwo"/>
                                        <field name="week_tminusone"/>
                                        <field name="current_week"/>
                                    </list>
                                </field>
                            </page>
                            <page name="milestone" string="Milestone" invisible="1">
                                <field name="milestone_history_ids" context="{'default_project_id': project_id}">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="is_reached" optional="show"/>
                                        <field name="is_deadline_exceeded" invisible="1"/>
                                        <field name="start_date"/>
                                        <field name="deadline"/>
                                        <field name="status"
                                               readonly="parent.last_report != True"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                        <group>
                            <field name="message"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="project_progress_view_tree" model="ir.ui.view">
            <field name="name">project.progress.view.tree</field>
            <field name="model">project.progress</field>
            <field name="arch" type="xml">
                <list default_order="create_date desc">
                    <field name="name"/>
                    <field name="create_date"/>
                    <field name="project_id"/>
                    <field name="company_id" invisible="1"/>
                    <field name="global_progress"/>
                    <field name="remaining_hours"/>
                    <field name="left_hours"/>
                    <field name="go_live_date"/>
                    <field name="phase_id" optional="hide"/>
                    <field name="status"/>
                </list>
            </field>
        </record>

         <record id="project_progress_view_search_view" model="ir.ui.view">
            <field name="name">project.progress.search.view</field>
            <field name="model">project.progress</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <filter string="Draft" name="status" domain="[('status', '=', 'draft')]"/>
                    <filter string="Sent" name="status" domain="[('status', '=', 'sent')]"/>
                    <filter string="Signed" name="status" domain="[('status', '=', 'signed')]"/>

                        <filter string="Status" name="status"
                                context="{'group_by':'status'}"/>


                        <filter string="Project" name="project_id"
                                context="{'group_by':'project_id'}"/>
                         <filter string="Phase" name="phase_id"
                                context="{'group_by':'phase_id'}"/>

                </search>
            </field>
        </record>

        <record id="project_progress_action" model="ir.actions.act_window">
            <field name="name">Project Progress Report</field>
            <field name="res_model">project.progress</field>
            <field name="view_mode">list,form</field>
            <!--            <field name="context">{'default_project_id': active_id}</field>-->
            <!--            <field name="domain">[('project_id', '=', active_id)]</field>-->
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No Project Progress Report found. Let's create one!
                </p>
            </field>
        </record>

<!--        embedded action-->
        <record id="project_embedded_action_project_progress_report" model="ir.embedded.actions">
            <field name="parent_res_model">project.project</field>
            <field name="sequence">100</field>
            <field name="name">Project Progress Report</field>
            <field name="parent_action_id" ref="project.act_project_project_2_project_task_all"/>
            <field name="python_method">action_get_project_progress_report</field>
            <field name="context">{"from_embedded_action": true}</field>
        </record>

        <menuitem id="project_progress_menu"
                  name="Project Progress Report"
                  action="project_progress_action"
                  parent="project.menu_main_pm"
                  sequence="16"/>

    </data>
</odoo>
