<odoo>
    <data>
        <record id="project_milestone_view_form_inherit_custom" model="ir.ui.view">
            <field name="name">project.milestone.view.form.inherit.custom</field>
            <field name="model">project.milestone</field>
            <field name="inherit_id" ref="project.project_milestone_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="start_date"/>
                </xpath>
                <xpath expr="//field[@name='is_reached']" position="after">
                    <field name="status"/>
                </xpath>
            </field>
        </record>

        <record id="project_milestone_view_tree_inherit_custom" model="ir.ui.view">
            <field name="name">project.milestone.view.tree.inherit.custom</field>
            <field name="model">project.milestone</field>
            <field name="inherit_id" ref="project.project_milestone_view_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="start_date"/>
                </xpath>
                <xpath expr="//field[@name='is_reached']" position="after">
                    <field name="status"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>