<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="country_list_view" model="ir.ui.view">
        <field name="name">country.list.view</field>
        <field name="model">country</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="sh_name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="country_form_view" model="ir.ui.view">
        <field name="name">country.form.view</field>
        <field name="model">country</field>
        <field name="arch" type="xml">
            <form>
                <group>
                <field name="name"/>
                <field name="sh_name"/>
                <field name="active"/>
                </group>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="country_action" model="ir.actions.act_window">
        <field name="name">country</field>
        <field name="res_model">country</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENUS -->
    <menuitem id="Localization" name="Countries"/>
    <menuitem id="country_child" name="Country" parent="Localization" action="country_action"/>



</odoo>
