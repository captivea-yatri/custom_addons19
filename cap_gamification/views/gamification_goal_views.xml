<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="cap_gamification_inherited_goal_form_view" model="ir.ui.view">
        <field name="name">Goal Form</field>
        <field name="model">gamification.goal</field>
        <field name="inherit_id" ref="gamification.goal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form[1]/sheet[1]/group[1]/group[3]/div[2]" position="after">
                <label for="hours_of_internal_p2_p3"/>
                <div>
                    <field name="hours_of_internal_p2_p3" class="oe_inline"/>
                </div>
                <label for="current_val_with_internal_p2_p3"/>
                <div>
                    <field name="current_val_with_internal_p2_p3" class="oe_inline"/>
                </div>
            </xpath>
        </field>
    </record>

<!--    todo need to check two buttons Goal fail and goal reach-->
</odoo>