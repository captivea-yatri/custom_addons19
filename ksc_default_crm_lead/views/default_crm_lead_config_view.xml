<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="default_crm_lead_config_tree_view" model="ir.ui.view">
        <field name="name">default.crm.lead.config.tree</field>
        <field name="model">default.crm.lead.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="website_id"/>
                <field name="country_id"/>
                <field name="company_id"/>
                <field name="team_id"/>
            </list>
        </field>
    </record>

    <record id="default_crm_lead_config_form_view" model="ir.ui.view">
        <field name="name">default.crm.lead.config.form</field>
        <field name="model">default.crm.lead.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="website_id" required="True"
                                   options="{'no_quick_create': True, 'no_open':True,'no_create': True}"/>
                            <field name="country_id" options="{'no_open': True, 'no_create': True}" required="True"/>
                        </group>
                        <group>
                            <field name="company_id" options="{'no_open': True, 'no_create': True}" required="True"/>
                            <field name="team_id" options="{'no_open': True, 'no_create': True}" required="True"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="default_crm_lead_config_action" model="ir.actions.act_window">
        <field name="name">CRM Lead Config</field>
        <field name="res_model">default.crm.lead.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem action="default_crm_lead_config_action"
              id="default_crm_lead_config_menu"
              parent="crm.crm_menu_config"
              sequence="6"/>

</odoo>
