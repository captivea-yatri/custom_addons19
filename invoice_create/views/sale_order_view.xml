<odoo>
    <data>
        <record id="view_order_form_inherit_invoice_on_confirm" model="ir.ui.view">
            <field name="name">view.order.form.inherit.invoice.on.confirm</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">

                <xpath expr="//button[@name='action_confirm' and contains(@invisible, 'draft')]" position="replace">
                    <button string="Confirm "
                            name="action_confirm"
                            type="object"
                            class="btn-primary"
                            data-hotkey="q"
                            context="{'validate_analytic': True}"
                            invisible="state != 'draft'"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
