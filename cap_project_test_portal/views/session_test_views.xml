<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="session_test_portal_tree_view" model="ir.ui.view">
        <field name="name">session.test.portal.tree.view</field>
        <field name="model">session.test</field>
        <field name="arch" type="xml">
            <list default_order="date desc">
                <field name="name"/>
                <field name="date"/>
                <field name="branch"/>
                <field name="phase_id"/>
                <field name="domain_ids" widget="many2many_tags"/>
                <field name="task_ids" widget="many2many_tags"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="assigned_user_id"/>
                <field name="pick_only" string="Pick only test that failed last time"/>
                <field name="no_of_success_execution_test_object" string="Success"/>
                <field name="no_of_failed_execution_test_object" string="Failed"/>
                <field name="no_of_skipped_execution_test_object" string="Skipped"/>
                <field name="no_of_todo_execution_test_object" string="To do"/>
                <field name="status" widget="badge" decoration-info="status == 'draft'"
                       decoration-warning="status == ('closed')" decoration-success="status == 'signed'"/>
            </list>
        </field>
    </record>

    <record id="session_test_portal_form_view" model="ir.ui.view">
        <field name="name">session.test.portal.form.view</field>
        <field name="model">session.test</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_execution_test"
                            string="Initialize Tests" type="object"
                            invisible="hide_the_initialize_button == True or status == 'cancel'" class="btn btn-primary"/>
                    <button name="session_test_message_auto_subscribe_notify"
                            string="Send Invitation Email To Assigned User" type="object"
                            invisible="hide_the_initialize_button == False or status in ['closed', 'signed', 'cancel']"/>
                    <button name="send_email" string="Sign And Validate"
                            type="object"
                            invisible="status in ['draft','sent','in progress','signed','cancel'] or hide_button_sign_and_validate == True"
                            class="btn btn-primary"/>
                    <button name="action_close_the_session" string="Close the Session" type="object"
                            class="btn btn-primary"
                            invisible="is_assigned_user == False or status in ['closed', 'signed', 'cancel'] or hide_the_initialize_button == False"/>
                    <button name="cancel_execution_test"
                                    type="object"  string="Cancel"
                                    class="oe_stat_button"
                                    invisible="status not in ['draft', 'sent', 'in progress']"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" string="Session"
                                   readonly="hide_the_initialize_button == True"/>
                            <field name="date" string="Date"
                                   readonly="hide_the_initialize_button == True"/>
                            <field name="project_id" readonly="1"
                                   options="{'no_open': True}"/>
                            <field name="assigned_user_id"
                                   readonly="hide_the_initialize_button == True"
                                   options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                            <field name="signer_id" required="1"
                                   readonly="hide_the_initialize_button == True"
                                   options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>
                            <field name="hide_the_initialize_button" invisible="1"/>
                            <field name="file_name" invisible="1"/>
                            <field name="file" filename="file_name"/>
                            <field name="attachment_id" invisible="1"/>
                            <field name="sign_request_id" invisible="1"/>
                            <field name="hide_button_sign_and_validate" invisible="1"/>
                            <!--                            <field name="hide_button_mark_all_test_as_as_skip" invisible="1"/>-->
                            <field name="assigned_user_ids" invisible="1"/>
                            <field name="is_assigned_user" invisible="1"/>
                        </group>
                        <group>
                            <field name="branch" string="Branch"
                                   readonly="hide_the_initialize_button == True"/>
                            <field name="pick_only" string="Pick only"
                                   readonly="hide_the_initialize_button == True"/>
                            <field name="phase_id" context="{'project_id': project_id}"
                                   readonly="hide_the_initialize_button == True"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="domain_ids" widget="many2many_tags"
                                   readonly="hide_the_initialize_button == True"
                                   context="{'project_id': project_id}"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="tag_ids" widget="many2many_tags"
                                   readonly="hide_the_initialize_button == True"
                                   context="{'project_id': project_id}"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="message" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Task Validation Status">
                            <field name="task_validation_status_ids" mode="list"
                                   context="{
                                             'form_view_ref': 'cap_project_test_portal.task_validation_status_portal_form'}">
                                <list create="0" delete="0">
                                    <field name="task_id"/>
                                    <field name="domain_id"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_session_test_portal" model="ir.actions.act_window">
        <field name="name">Session Test</field>
        <field name="res_model">session.test</field>
        <field name="view_mode">list,form</field>
<!--        <field name="context">{-->
<!--            'default_project_id': active_id,-->
<!--            'active_id_chatter': active_id,-->
<!--        }</field>-->
        <field name="view_ids"
               eval="[(5, 0, 0),
                          (0, 0, {'view_mode': 'list', 'view_id': ref('session_test_portal_tree_view')}),
                          (0, 0, {'view_mode': 'form', 'view_id': ref('session_test_portal_form_view')})]"/>
    </record>

    <record id="action_session_test_portal_for_launch_session" model="ir.actions.act_window">
        <field name="name">Session Test</field>
        <field name="res_model">session.test</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="session_test_portal_form_view"/>
    </record>

    <!-- *************** Task Validation Status views *************** -->

    <record id="task_validation_status_portal_form" model="ir.ui.view">
        <field name="name">task.validation.status.portal.form.view</field>
        <field name="model">task.validation.status</field>
        <field name="arch" type="xml">
            <form create="0" delete="0">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_execution_test"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-check-square-o icon">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Execution</span>
                                <span class="o_stat_text">Test</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="task_id" readonly="True"
                                   options="{'no_open': True}"/>
                            <field name="mark_feedback_as_readonly" invisible="1"/>
                            <field name="feedback_readonly" invisible="1"/>
                        </group>
                        <group>
                            <field name="domain_id" readonly="True" options="{'no_open': True}"/>
                            <field name="status" readonly="True"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Execution Test">
                            <field name="execution_test_ids" readonly="1" mode="list">
                                <list no_open="1">
                                    <field name="test_id" string="Task"/>
                                    <field name="description" string="Description" class="text-wrap"/>
                                    <field name="status" string="Result"/>
                                    <field name="is_session_test_draft" column_invisible="True"/>
                                    <field name="session_test_id" column_invisible="True"/>
                                    <button name="set_status_success"
                                            string="OK" type="object"
                                            class="btn btn-success"
                                            invisible="status in ['success', 'failed', 'skipped'] or is_session_test_draft == False"/>
                                    <button name="set_status_failed" string="KO" type="object" class="btn btn-danger"
                                            invisible="status in ['success', 'failed', 'skipped'] or is_session_test_draft == False"/>
                                    <button name="set_status_skip" string="Skip" type="object" class="btn btn-warning"
                                            invisible="status in ['success', 'failed', 'skipped'] or is_session_test_draft == False"/>
                                    <button name="set_status_Todo" string="Todo" type="object" class="btn btn-info"
                                            invisible="status == 'To do' or is_session_test_draft == False"/>
                                </list>
                            </field>
                            <!--                                   context="{'tree_view_ref': 'cap_project_test_portal.execution_test_portal_list_for_page'}"/>-->
                        </page>
                        <page string="Feedback" name="feedback">
                            <field name="feedback_ids"
                                   readonly="mark_feedback_as_readonly == True or feedback_readonly == True"
                                   context="{'tree_view_ref': 'cap_project_test_portal.feedback_portal_view_list',
                                             'form_view_ref': 'cap_project_test_portal.feedback_portal_view_form'}">
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- *************** execution test views *************** -->
    <record id="execution_test_portal_list" model="ir.ui.view">
        <field name="name">execution.test.portal.tree.view</field>
        <field name="model">execution.test</field>
        <field name="arch" type="xml">
            <list>
                <field name="test_id" string="Task"/>
                <field name="status" string="Result"/>
                <field name="feedback_ids" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="execution_test_portal_form" model="ir.ui.view">
        <field name="name">execution.test.portal.form.view</field>
        <field name="model">execution.test</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="set_status_success"
                            string="OK" type="object"
                            class="btn btn-success"
                            invisible="status in ['success', 'failed', 'skipped'] or is_session_test_draft == False"/>
                    <button name="set_status_failed" string="KO" type="object" class="btn btn-danger"
                             invisible="status in ['success', 'failed', 'skipped'] or is_session_test_draft == False"/>
                    <button name="set_status_skip" string="Skip" type="object" class="btn btn-warning"
                             invisible="status in ['success', 'failed', 'skipped'] or is_session_test_draft == False"/>
                    <button name="set_status_Todo" string="Todo" type="object" class="btn btn-info"
                             invisible="status == 'To do' or is_session_test_draft == False"/>
                    <field name="status" string="Status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="task_id" readonly="True" options="{'no_open': True}"/>
                        </group>
                        <group>
                            <field name="domain_id" readonly="True" options="{'no_open': True}"/>
                            <field name="is_session_test_draft" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Feedback" invisible="1">
                            <field name="feedback_ids" invisible="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- *************** Feedback views *************** -->

    <record id="feedback_portal_view_list" model="ir.ui.view">
        <field name="name">feedback.portal.list.view</field>
        <field name="model">project.feedback</field>
        <field name="arch" type="xml">
            <list delete="0">
                <field name="name" string="Feedback"/>
                <field name="description" string="Description"/>
                <field name="status" string="Status"/>
            </list>
        </field>
    </record>

    <record id="feedback_portal_view_form" model="ir.ui.view">
        <field name="name">feedback.portal.form.view</field>
        <field name="model">project.feedback</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" string="Status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" string="Feedback Summary"/>
                        <field name="test_id" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!--  inherited session view and added launch session button   -->

    <record id="session_test_inherited_form_view" model="ir.ui.view">
        <field name="name">session.test.form.view</field>
        <field name="model">session.test</field>
        <field name="inherit_id" ref="cap_project_test.session_test_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button class="oe_stat_button" name="action_launch_session" type="object"
                        icon="fa-light fa-rocket" context="{'project_id': project_id}">
                    <div class="o_stat_info o_field_widget">
                        <span class="o_stat_text">
                            Launch
                        </span>
                        <span class="o_stat_text">
                            Session
                        </span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>

