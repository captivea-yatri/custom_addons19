<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="session_test_email_template" model="mail.template">
        <field name="name">Session Test: Email Template</field>
        <field name="model_id" ref="cap_project_test.model_session_test"/>
        <field name="subject">Document Request</field>
        <field name="email_to">{{ object.project_id.partner_id.email }}</field>
        <field name="description">Sent to partner when requesting a document from them</field>
        <field name="body_html" type="html">
            <div>
                <p>Hello Guys, This is system generated Mail.</p>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>